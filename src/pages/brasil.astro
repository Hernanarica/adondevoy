---
import GalleryPage from '../layouts/GalleryPage.astro';
import { getImages, getImagesFromCaptions, getFolderCaptions, type GallerySectionData } from '../lib/gallery';

const siteBase = 'https://adondevoy.com.ar';

const sections: GallerySectionData[] = [
  { anchor: 'serra-verde-express', folder: 'Brasil/SerraVerdeExpress', title: 'TREN SERRA VERDE EXPRESS', sub: 'de Curitiba a Paranaguá', label: 'Tren Serra Verde Express', photos: getImages('Brasil/SerraVerdeExpress'), captions: getFolderCaptions('Brasil/SerraVerdeExpress') },
  { anchor: 'canela', folder: 'Brasil/Canela', title: 'PORTO ALEGRE Y CANELA', label: 'Canela', photos: getImages('Brasil/Canela'), captions: getFolderCaptions('Brasil/Canela') },
  { anchor: 'maceio-ilheus', folder: 'Brasil/Maceio-Ilheus', title: 'MACEIÓ E ILHÉUS', label: 'Maceió e Ilhéus', photos: getImages('Brasil/Maceio-Ilheus'), captions: getFolderCaptions('Brasil/Maceio-Ilheus') },
  { anchor: 'salvador', folder: 'Brasil/Salvador', title: 'SALVADOR DE BAHÍA', label: 'Salvador', photos: getImages('Brasil/Salvador'), captions: getFolderCaptions('Brasil/Salvador') },
  { anchor: 'guaruja-santos-san-pablo', folder: 'Brasil/Guaruja-Santos-SanPablo', title: 'TRES CIUDADES BRASILEÑAS', sub: 'Guarujá · Santos · San Pablo', label: 'Guarujá · Santos · SP', photos: getImages('Brasil/Guaruja-Santos-SanPablo'), captions: getFolderCaptions('Brasil/Guaruja-Santos-SanPablo') },
  { anchor: 'gramado', folder: 'Brasil/Gramado', title: 'PORTO ALEGRE Y GRAMADO', label: 'Gramado', photos: getImages('Brasil/Gramado'), captions: getFolderCaptions('Brasil/Gramado') },
  { anchor: 'rio-de-janeiro', folder: 'Brasil/Rio-de-Janeiro', title: 'RÍO DE JANEIRO', label: 'Río de Janeiro', photos: getImagesFromCaptions('Brasil/Rio-de-Janeiro'), captions: getFolderCaptions('Brasil/Rio-de-Janeiro') },
  { anchor: 'petropolis', folder: 'Brasil/Petropolis', title: 'PETRÓPOLIS', label: 'Petrópolis', photos: getImages('Brasil/Petropolis'), captions: getFolderCaptions('Brasil/Petropolis') },
  { anchor: 'ilha-grande-ilhabela', folder: 'Brasil/IlhaGrande-Ilhabela', title: 'ILHA GRANDE E ILHABELA', label: 'Ilha Grande · Ilhabela', photos: getImages('Brasil/IlhaGrande-Ilhabela'), captions: getFolderCaptions('Brasil/IlhaGrande-Ilhabela') },
  { anchor: 'portobelo-blumenau-camboriu', folder: 'Brasil/Portobelo-Blumenau-Camboriu', title: 'BLUMENAU Y CAMBORIÚ', label: 'Blumenau · Camboriú', photos: getImages('Brasil/Portobelo-Blumenau-Camboriu'), captions: getFolderCaptions('Brasil/Portobelo-Blumenau-Camboriu') },
  { anchor: 'buzios-paraty', folder: 'Brasil/Buzios-Paraty', title: 'BÚZIOS Y PARATÍ', label: 'Búzios · Paratí', photos: getImages('Brasil/Buzios-Paraty'), captions: getFolderCaptions('Brasil/Buzios-Paraty') },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'ImageGallery',
  name: 'Brasil — Fotografía de viajes',
  description: 'Galería fotográfica de Brasil: Río de Janeiro, Salvador, Gramado, Ilha Grande, Búzios, Petrópolis y más. Fotografías de Orlando Moure.',
  author: { '@type': 'Person', name: 'Orlando Moure', url: siteBase },
  url: `${siteBase}/brasil`,
};
---

<GalleryPage
  currentCountry="brasil"
  sections={sections}
  title="Brasil — Fotografía de viajes"
  description="Galería fotográfica de Brasil: Río de Janeiro, Salvador, Gramado, Ilha Grande, Búzios, Petrópolis y más. Fotografías de Orlando Moure."
  canonical={`${siteBase}/brasil`}
  ogImage={`${siteBase}/Brasil/SerraVerdeExpress/00.webp`}
  pageHeading="Brasil — Fotografía de viajes"
  jsonLd={jsonLd}
/>
