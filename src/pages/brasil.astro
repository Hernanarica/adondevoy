---
import { readdirSync, readFileSync } from 'node:fs';
import { join } from 'node:path';

import 'fullpage.js/dist/fullpage.min.css';
import 'swiper/css';
import 'swiper/css/navigation';

import Layout from '../layouts/Layout.astro';

function getImages(folder: string): string[] {
  const dir = join(process.cwd(), 'public', folder);
  return readdirSync(dir)
    .filter(f => /\.(jpe?g|png|webp|avif|gif)$/i.test(f) && !/^00\./i.test(f))
    .sort((a, b) => a.localeCompare(b, undefined, { numeric: true, sensitivity: 'base' }));
}

interface CaptionEntry { title?: string; description?: string }

function getFolderCaptions(folder: string): Record<string, CaptionEntry> {
  const jsonPath = join(process.cwd(), 'public', folder, 'fotos.json');
  try {
    const data: Array<{ photo: string; title: string; description: string }> =
      JSON.parse(readFileSync(jsonPath, 'utf-8'));
    return Object.fromEntries(
      data.map(item => [item.photo, { title: item.title || undefined, description: item.description || undefined }])
    );
  } catch {
    return {};
  }
}

function getImagesFromCaptions(folder: string): string[] {
  const jsonPath = join(process.cwd(), 'public', folder, 'fotos.json');
  try {
    const data: Array<{ photo: string }> = JSON.parse(readFileSync(jsonPath, 'utf-8'));
    return data.map(e => e.photo).filter(p => p !== '00.webp');
  } catch {
    return [];
  }
}

const serraVerdeExpressPhotos       = getImages('Brasil/SerraVerdeExpress');
const canelaPhotos                  = getImages('Brasil/Canela');
const maceioIlheusPhotos            = getImages('Brasil/Maceio-Ilheus');
const salvadorPhotos                = getImages('Brasil/Salvador');
const guarujaSantosSanPabloPhotos   = getImages('Brasil/Guaruja-Santos-SanPablo');
const gramadoPhotos                 = getImages('Brasil/Gramado');
const rioDeJaneiroPhotos            = getImagesFromCaptions('Brasil/Rio-de-Janeiro');
const petropolisPhotos              = getImages('Brasil/Petropolis');
const ilhaGrandeIlhabelaPhotos      = getImages('Brasil/IlhaGrande-Ilhabela');
const portobloBlumenauCamboriuPhotos = getImages('Brasil/Portobelo-Blumenau-Camboriu');
const buziosParatyPhotos            = getImages('Brasil/Buzios-Paraty');

const captions: Record<string, Record<string, CaptionEntry>> = {
  SerraVerdeExpress:       getFolderCaptions('Brasil/SerraVerdeExpress'),
  Canela:                  getFolderCaptions('Brasil/Canela'),
  MaceioIlheus:            getFolderCaptions('Brasil/Maceio-Ilheus'),
  Salvador:                getFolderCaptions('Brasil/Salvador'),
  GuarujaSantosSanPablo:   getFolderCaptions('Brasil/Guaruja-Santos-SanPablo'),
  Gramado:                 getFolderCaptions('Brasil/Gramado'),
  RioDeJaneiro:            getFolderCaptions('Brasil/Rio-de-Janeiro'),
  Petropolis:              getFolderCaptions('Brasil/Petropolis'),
  IlhaGrandeIlhabela:      getFolderCaptions('Brasil/IlhaGrande-Ilhabela'),
  PortobloBlumenauCamboriu: getFolderCaptions('Brasil/Portobelo-Blumenau-Camboriu'),
  BuziosParaty:            getFolderCaptions('Brasil/Buzios-Paraty'),
};

const currentCountry = 'brasil';

const siteBase = 'https://adondevoy.com.ar';
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'ImageGallery',
  name: 'Brasil — Fotografía de viajes',
  description: 'Galería fotográfica de Brasil: Río de Janeiro, Salvador, Gramado, Ilha Grande, Búzios, Petrópolis y más. Fotografías de Orlando Moure.',
  author: { '@type': 'Person', name: 'Orlando Moure', url: siteBase },
  url: `${siteBase}/brasil`,
};
