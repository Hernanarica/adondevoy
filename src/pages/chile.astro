---
import GalleryPage from '../layouts/GalleryPage.astro';
import { getImages, getFolderCaptions, type GallerySectionData } from '../lib/gallery';

const siteBase = 'https://adondevoy.com.ar';

const sections: GallerySectionData[] = [
  {
    anchor: 'coquimbo-la-serena',
    folder: 'Chile/1-Coquimbo-LaSerena',
    title: 'COQUIMBO Y LA SERENA',
    label: 'Coquimbo · La Serena',
    photos: getImages('Chile/1-Coquimbo-LaSerena'),
    captions: getFolderCaptions('Chile/1-Coquimbo-LaSerena'),
  },
  {
    anchor: 'vina-del-mar-valparaiso',
    folder: 'Chile/2-VinadelMar-Valparaiso',
    title: 'VIÑA DEL MAR',
    sub: 'Valparaíso',
    label: 'Viña del Mar · Valparaíso',
    photos: getImages('Chile/2-VinadelMar-Valparaiso'),
    captions: getFolderCaptions('Chile/2-VinadelMar-Valparaiso'),
  },
  {
    anchor: 'santiago',
    folder: 'Chile/3-Santiago',
    title: 'SANTIAGO DE CHILE',
    label: 'Santiago',
    photos: getImages('Chile/3-Santiago'),
    captions: getFolderCaptions('Chile/3-Santiago'),
  },
  {
    anchor: 'talcahuano-concepcion',
    folder: 'Chile/4-Talcahuano-Concepcion',
    title: 'TALCAHUANO',
    sub: 'Concepción',
    label: 'Talcahuano · Concepción',
    photos: getImages('Chile/4-Talcahuano-Concepcion'),
    captions: getFolderCaptions('Chile/4-Talcahuano-Concepcion'),
  },
  {
    anchor: 'valdivia',
    folder: 'Chile/5-Valdivia',
    title: 'VALDIVIA',
    label: 'Valdivia',
    photos: getImages('Chile/5-Valdivia'),
    captions: getFolderCaptions('Chile/5-Valdivia'),
  },
  {
    anchor: 'puerto-montt',
    folder: 'Chile/6-PtoMontt',
    title: 'PUERTO MONTT',
    label: 'Puerto Montt',
    photos: getImages('Chile/6-PtoMontt'),
    captions: getFolderCaptions('Chile/6-PtoMontt'),
  },
  {
    anchor: 'chacabuco-coyhaique',
    folder: 'Chile/7-Chacabuco-Coyhaique',
    title: 'PUERTO CHACABUCO',
    sub: 'Coyhaique',
    label: 'Chacabuco · Coyhaique',
    photos: getImages('Chile/7-Chacabuco-Coyhaique'),
    captions: getFolderCaptions('Chile/7-Chacabuco-Coyhaique'),
  },
  {
    anchor: 'torres-del-paine',
    folder: 'Chile/8-Torres-de-Paine',
    title: 'TORRES DEL PAINE',
    label: 'Torres del Paine',
    photos: getImages('Chile/8-Torres-de-Paine'),
    captions: getFolderCaptions('Chile/8-Torres-de-Paine'),
  },
  {
    anchor: 'punta-arenas',
    folder: 'Chile/9-PuntaArenas',
    title: 'PUNTA ARENAS',
    label: 'Punta Arenas',
    photos: getImages('Chile/9-PuntaArenas'),
    captions: getFolderCaptions('Chile/9-PuntaArenas'),
  },
  {
    anchor: 'cabo-de-hornos',
    folder: 'Chile/10-Cabo-de-Hornos',
    title: 'CABO DE HORNOS',
    label: 'Cabo de Hornos',
    photos: getImages('Chile/10-Cabo-de-Hornos'),
    captions: getFolderCaptions('Chile/10-Cabo-de-Hornos'),
  },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'ImageGallery',
  name: 'Chile — Fotografía de viajes',
  description: 'Galería fotográfica de Chile: Valparaíso, Santiago, Torres del Paine, Cabo de Hornos, Patagonia, Punta Arenas y más. Fotografías de Orlando Moure.',
  author: { '@type': 'Person', name: 'Orlando Moure', url: siteBase },
  url: `${siteBase}/chile`,
};
---

<GalleryPage
  currentCountry="chile"
  sections={sections}
  title="Chile — Fotografía de viajes"
  description="Galería fotográfica de Chile: Valparaíso, Santiago, Torres del Paine, Cabo de Hornos, Patagonia, Punta Arenas y más. Fotografías de Orlando Moure."
  canonical={`${siteBase}/chile`}
  pageHeading="Chile — Fotografía de viajes"
  jsonLd={jsonLd}
/>
