---
import { readdirSync, readFileSync } from 'node:fs';
import { join } from 'node:path';

import 'fullpage.js/dist/fullpage.min.css';
import 'swiper/css';
import 'swiper/css/navigation';

import Layout from '../layouts/Layout.astro';

function getImages(folder: string): string[] {
  const dir = join(process.cwd(), 'public', folder);
  return readdirSync(dir)
    .filter(f => /\.(jpe?g|png|webp|avif|gif)$/i.test(f) && !/^00\./i.test(f))
    .sort((a, b) => a.localeCompare(b, undefined, { numeric: true, sensitivity: 'base' }));
}

interface CaptionEntry { title?: string; description?: string }

function getFolderCaptions(folder: string): Record<string, CaptionEntry> {
  const jsonPath = join(process.cwd(), 'public', folder, 'fotos.json');
  try {
    const data: Array<{ photo: string; title: string; description: string }> =
      JSON.parse(readFileSync(jsonPath, 'utf-8'));
    return Object.fromEntries(
      data.map(item => [item.photo, { title: item.title || undefined, description: item.description || undefined }])
    );
  } catch {
    return {};
  }
}

const piriápolisPhotos       = getImages('Uruguay/Piriapolis');
const montevideoPhotos       = getImages('Uruguay/Montevideo');
const lobosGorritiPhotos     = getImages('Uruguay/Lobos-Gorriti');
const puntaDelEstePhotos     = getImages('Uruguay/Punta-del-Este');
const anchorenaPhotos        = getImages('Uruguay/Anchorena');
const cincoColoniasPhotos    = getImages('Uruguay/CincoColonias');
const coloniaSacramentoPhotos = getImages('Uruguay/ColoniaSacramento');
const cincoMuseosPhotos      = getImages('Uruguay/CincoMuseos');
const carmeloPhotos          = getImages('Uruguay/Carmelo');

const captions: Record<string, Record<string, CaptionEntry>> = {
  Piriapolis:        getFolderCaptions('Uruguay/Piriapolis'),
  Montevideo:        getFolderCaptions('Uruguay/Montevideo'),
  LobosGorriti:      getFolderCaptions('Uruguay/Lobos-Gorriti'),
  PuntaDelEste:      getFolderCaptions('Uruguay/Punta-del-Este'),
  Anchorena:         getFolderCaptions('Uruguay/Anchorena'),
  CincoColonias:     getFolderCaptions('Uruguay/CincoColonias'),
  ColoniaSacramento: getFolderCaptions('Uruguay/ColoniaSacramento'),
  CincoMuseos:       getFolderCaptions('Uruguay/CincoMuseos'),
  Carmelo:           getFolderCaptions('Uruguay/Carmelo'),
};

const currentCountry = 'uruguay';
