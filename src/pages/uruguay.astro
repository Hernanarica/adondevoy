---
import GalleryPage from '../layouts/GalleryPage.astro';
import { getImages, getFolderCaptions, type GallerySectionData } from '../lib/gallery';

const siteBase = 'https://adondevoy.com.ar';

const sections: GallerySectionData[] = [
  {
    anchor: 'piriapolis',
    folder: 'Uruguay/Piriapolis',
    title: 'PIRIÁPOLIS',
    label: 'Piriápolis',
    photos: getImages('Uruguay/Piriapolis'),
    captions: getFolderCaptions('Uruguay/Piriapolis'),
  },
  {
    anchor: 'montevideo',
    folder: 'Uruguay/Montevideo',
    title: 'MONTEVIDEO',
    label: 'Montevideo',
    photos: getImages('Uruguay/Montevideo'),
    captions: getFolderCaptions('Uruguay/Montevideo'),
  },
  {
    anchor: 'lobos-gorriti',
    folder: 'Uruguay/Lobos-Gorriti',
    title: 'LOBOS Y GORRITI',
    label: 'Lobos y Gorriti',
    photos: getImages('Uruguay/Lobos-Gorriti'),
    captions: getFolderCaptions('Uruguay/Lobos-Gorriti'),
  },
  {
    anchor: 'punta-del-este',
    folder: 'Uruguay/Punta-del-Este',
    title: 'PUNTA DEL ESTE',
    label: 'Punta del Este',
    photos: getImages('Uruguay/Punta-del-Este'),
    captions: getFolderCaptions('Uruguay/Punta-del-Este'),
  },
  {
    anchor: 'anchorena',
    folder: 'Uruguay/Anchorena',
    title: 'ANCHORENA',
    label: 'Anchorena',
    photos: getImages('Uruguay/Anchorena'),
    captions: getFolderCaptions('Uruguay/Anchorena'),
  },
  {
    anchor: 'cinco-colonias',
    folder: 'Uruguay/CincoColonias',
    title: 'CINCO COLONIAS URUGUAYAS',
    label: 'Cinco Colonias',
    photos: getImages('Uruguay/CincoColonias'),
    captions: getFolderCaptions('Uruguay/CincoColonias'),
  },
  {
    anchor: 'colonia-sacramento',
    folder: 'Uruguay/ColoniaSacramento',
    title: 'COLONIA SACRAMENTO',
    label: 'Colonia Sacramento',
    photos: getImages('Uruguay/ColoniaSacramento'),
    captions: getFolderCaptions('Uruguay/ColoniaSacramento'),
  },
  {
    anchor: 'cinco-museos',
    folder: 'Uruguay/CincoMuseos',
    title: 'CINCO MUSEOS',
    label: 'Cinco Museos',
    photos: getImages('Uruguay/CincoMuseos'),
    captions: getFolderCaptions('Uruguay/CincoMuseos'),
  },
  {
    anchor: 'carmelo',
    folder: 'Uruguay/Carmelo',
    title: 'CARMELO',
    label: 'Carmelo',
    photos: getImages('Uruguay/Carmelo'),
    captions: getFolderCaptions('Uruguay/Carmelo'),
  },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'ImageGallery',
  name: 'Uruguay — Fotografía de viajes',
  description: 'Galería fotográfica de Uruguay: Montevideo, Punta del Este, Colonia Sacramento, Piriápolis, Carmelo y más. Fotografías de Orlando Moure.',
  author: { '@type': 'Person', name: 'Orlando Moure', url: siteBase },
  url: `${siteBase}/uruguay`,
};
---

<GalleryPage
  currentCountry="uruguay"
  sections={sections}
  title="Uruguay — Fotografía de viajes"
  description="Galería fotográfica de Uruguay: Montevideo, Punta del Este, Colonia Sacramento, Piriápolis, Carmelo y más. Fotografías de Orlando Moure."
  canonical={`${siteBase}/uruguay`}
  ogImage={`${siteBase}/Uruguay/Piriapolis/00.webp`}
  pageHeading="Uruguay — Fotografía de viajes"
  jsonLd={jsonLd}
/>
