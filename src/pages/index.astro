---
import GalleryPage from '../layouts/GalleryPage.astro';
import {
  getImages,
  getImagesRecursive,
  getFolderCaptions,
  getFolderCaptionsRecursive,
  type GallerySectionData,
} from '../lib/gallery';

const siteBase = 'https://adondevoy.com.ar';

const sections: GallerySectionData[] = [
  { anchor: 'van-gogh', folder: 'Argentina/VanGogh', title: 'VAN GOGH', label: 'Van Gogh', photos: getImages('Argentina/VanGogh'), captions: getFolderCaptions('Argentina/VanGogh') },
  { anchor: 'halloween', folder: 'Argentina/Halloween', title: 'HALLOWEEN', label: 'Halloween', photos: getImagesRecursive('Argentina/Halloween'), captions: getFolderCaptionsRecursive('Argentina/Halloween') },
  { anchor: 'messi', folder: 'Argentina/Messi', title: 'MESSI', label: 'Messi', photos: getImages('Argentina/Messi'), captions: getFolderCaptions('Argentina/Messi') },
  { anchor: 'steve-mccurry', folder: 'Argentina/SteveMcCurry', title: 'STEVE MCCURRY', label: 'Steve McCurry', photos: getImages('Argentina/SteveMcCurry'), captions: getFolderCaptions('Argentina/SteveMcCurry') },
  { anchor: 'islas-malvinas', folder: 'Argentina/IslasMalvinas', title: 'ISLAS MALVINAS', sub: 'Cinco Cruceros', label: 'Islas Malvinas', body: 'A más de 1.200 kilómetros de la costa patagónica, las Islas Malvinas guardan una naturaleza única y una historia que marcó a la Argentina. A lo largo de cinco cruceros distintos, el mismo archipiélago siempre deparó nuevas sorpresas: pingüinos, lobos marinos, paisajes ventosos y una identidad propia que no se parece a nada.', photos: getImages('Argentina/IslasMalvinas'), captions: getFolderCaptions('Argentina/IslasMalvinas') },
  { anchor: 'trelew', folder: 'Argentina/Trelew-Tombo-Martires', title: 'TRELEW', sub: 'Tombo y Mártires', label: 'Trelew', photos: getImages('Argentina/Trelew-Tombo-Martires'), captions: getFolderCaptions('Argentina/Trelew-Tombo-Martires') },
  { anchor: 'martin-garcia', folder: 'Argentina/MartinGarcia', title: 'MARTÍN GARCÍA', sub: 'Isla', label: 'Martín García', photos: getImages('Argentina/MartinGarcia'), captions: getFolderCaptions('Argentina/MartinGarcia') },
  { anchor: 'banksy', folder: 'Argentina/Banksy', title: 'BANKSY', label: 'Banksy', photos: getImages('Argentina/Banksy'), captions: getFolderCaptions('Argentina/Banksy') },
  { anchor: 'mendoza', folder: 'Argentina/Mendoza', title: 'MENDOZA', sub: 'Ayer y Hoy', label: 'Mendoza', body: 'Fundada en 1561 y destacada por su belleza paisajística y su valioso patrimonio histórico, Mendoza se encuentra entre las provincias más desarrolladas de Argentina. Ubicada al pie de la Cordillera de los Andes, es la puerta obligada hacia el Océano Pacífico. Y gracias a la protección de las elevadas montañas andinas, su clima es templado con escasas lluvias y muy pocos días de viento. ¡Ven a conocerla!', photos: getImages('Argentina/Mendoza'), captions: getFolderCaptions('Argentina/Mendoza') },
  { anchor: 'gaiman', folder: 'Argentina/Gaiman', title: 'GAIMAN', sub: 'Patagonia galesa', label: 'Gaiman', photos: getImages('Argentina/Gaiman'), captions: getFolderCaptions('Argentina/Gaiman') },
  { anchor: 'ecoparque', folder: 'Argentina/Ecoparque', title: 'ECOPARQUE', sub: 'Buenos Aires', label: 'Ecoparque', photos: getImages('Argentina/Ecoparque'), captions: getFolderCaptions('Argentina/Ecoparque') },
  { anchor: 'cataratas', folder: 'Argentina/Cataratas', title: 'CATARATAS', sub: 'Iguazú', label: 'Cataratas', photos: getImages('Argentina/Cataratas'), captions: getFolderCaptions('Argentina/Cataratas') },
  { anchor: 'bariloche', folder: 'Argentina/Bariloche', title: 'BARILOCHE', sub: 'en familia', label: 'Bariloche', body: 'Enclavada en la Cordillera de los Andes y a orillas del lago Nahuel Huapi, Bariloche es una de las ciudades más bellas de la Patagonia argentina. Con su arquitectura de inspiración alpina, sus bosques milenarios y sus montañas nevadas, el paisaje invita a quedarse. Ideal para el esquí en invierno y el senderismo en verano, es el destino perfecto para disfrutar en familia durante todo el año. ¡Bienvenidos a la capital del chocolate y la aventura!', photos: getImages('Argentina/Bariloche'), captions: getFolderCaptions('Argentina/Bariloche') },
  { anchor: 'lautrec', folder: 'Argentina/Lautrec', title: 'LAUTREC', label: 'Lautrec', photos: getImages('Argentina/Lautrec'), captions: getFolderCaptions('Argentina/Lautrec') },
  { anchor: 'ushuaia-1', folder: 'Argentina/Ushuaia1', title: 'USHUAIA', sub: 'primera visita', label: 'Ushuaia I', photos: getImages('Argentina/Ushuaia1'), captions: getFolderCaptions('Argentina/Ushuaia1') },
  { anchor: 'ushuaia-2', folder: 'Argentina/Ushuaia2', title: 'USHUAIA', sub: 'segunda visita', label: 'Ushuaia II', photos: getImages('Argentina/Ushuaia2'), captions: getFolderCaptions('Argentina/Ushuaia2') },
  { anchor: 'tandil', folder: 'Argentina/Tandil', title: 'TANDIL', sub: 'Buenos Aires', label: 'Tandil', photos: getImages('Argentina/Tandil'), captions: getFolderCaptions('Argentina/Tandil') },
  { anchor: 'valadon', folder: 'Argentina/Valadon', title: 'VALADON', label: 'Valadon', photos: getImages('Argentina/Valadon'), captions: getFolderCaptions('Argentina/Valadon') },
  { anchor: 'patagonia-austral', folder: 'Argentina/PatagoniaAustral', title: 'PATAGONIA AUSTRAL', label: 'Patagonia Austral', photos: getImages('Argentina/PatagoniaAustral'), captions: getFolderCaptions('Argentina/PatagoniaAustral') },
  { anchor: 'peninsula-valdes', folder: 'Argentina/PeninsulaValdes', title: 'PENÍNSULA VALDÉS', label: 'Península Valdés', photos: getImages('Argentina/PeninsulaValdes'), captions: getFolderCaptions('Argentina/PeninsulaValdes') },
  { anchor: 'puerto-madryn', folder: 'Argentina/PuertoMadryn', title: 'PUERTO MADRYN', label: 'Puerto Madryn', photos: getImages('Argentina/PuertoMadryn'), captions: getFolderCaptions('Argentina/PuertoMadryn') },
  { anchor: 'calafate', folder: 'Argentina/Calafate', title: 'CALAFATE', sub: 'Maravillas Patagónicas', label: 'Calafate', photos: getImages('Argentina/Calafate'), captions: getFolderCaptions('Argentina/Calafate') },
  { anchor: 'la-cumbrecita', folder: 'Argentina/LaCumbrecita', title: 'LA CUMBRECITA', sub: 'Córdoba', label: 'La Cumbrecita', photos: getImages('Argentina/LaCumbrecita'), captions: getFolderCaptions('Argentina/LaCumbrecita') },
  { anchor: 'antartida', folder: 'Argentina/Antartida', title: 'ANTÁRTIDA', sub: 'Crucero Escénico a Antártida', body: 'Nos embarcamos en el barco "Azamara Journey" para navegar desde el Cabo de Hornos hasta la Península Antártica atravesando el mítico Pasaje Drake. Los cruceros escénicos suelen permanecer 5 días recorriendo islas, pasajes y canales. Salvo muy pocas excepciones, las embarcaciones no pueden realizar desembarques en la Antártida por la enorme biodiversidad que contiene y que un turismo masivo podría comprometer. Por ello, los cruceros están sujetos a normas internacionales muy exigentes que regulan el número de pasajeros que pueden desembarcar en el continente blanco. ¡Abrígate y ven con nosotros!', label: 'Antártida', photos: getImages('Argentina/Antartida'), captions: getFolderCaptions('Argentina/Antartida') },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'ImageGallery',
  name: 'Argentina — Fotografía de viajes',
  description: 'Galería fotográfica de Argentina: Bariloche, Mendoza, Patagonia Austral, Ushuaia, Islas Malvinas, Cataratas del Iguazú y más. Fotografías de Orlando Moure.',
  author: { '@type': 'Person', name: 'Orlando Moure', url: siteBase },
  url: siteBase,
};
---

<GalleryPage
  currentCountry="argentina"
  sections={sections}
  title="Argentina — Fotografía de viajes"
  description="Galería fotográfica de Argentina: Bariloche, Mendoza, Patagonia Austral, Ushuaia, Islas Malvinas, Cataratas del Iguazú y más. Fotografías de Orlando Moure."
  canonical={siteBase}
  ogImage={`${siteBase}/Argentina/VanGogh/00.webp`}
  pageHeading="Argentina — Fotografía de viajes"
  jsonLd={jsonLd}
/>
