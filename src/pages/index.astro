---
import { readdirSync, readFileSync } from 'node:fs';
import { join } from 'node:path';

import 'fullpage.js/dist/fullpage.min.css';
import 'swiper/css';
import 'swiper/css/navigation';

import Layout from '../layouts/Layout.astro';

function getImages(folder: string): string[] {
  const dir = join(process.cwd(), 'public', folder);
  return readdirSync(dir)
    .filter(f => /\.(jpe?g|png|webp|avif|gif)$/i.test(f) && !/^00\./i.test(f))
    .sort((a, b) => a.localeCompare(b, undefined, { numeric: true, sensitivity: 'base' }));
}

function getImagesRecursive(folder: string): string[] {
  const root = join(process.cwd(), 'public', folder);
  const out: string[] = [];
  function walk(rel: string): void {
    const abs = rel ? join(root, rel) : root;
    for (const entry of readdirSync(abs, { withFileTypes: true })) {
      const child = rel ? `${rel}/${entry.name}` : entry.name;
      if (entry.isDirectory()) {
        walk(child);
      } else if (/\.(jpe?g|png|webp|avif|gif)$/i.test(entry.name) && !/^00\./i.test(entry.name)) {
        out.push(child);
      }
    }
  }
  walk('');
  return out.sort((a, b) => a.localeCompare(b, undefined, { numeric: true, sensitivity: 'base' }));
}

interface CaptionEntry { title?: string; description?: string }

function getFolderCaptions(folder: string): Record<string, CaptionEntry> {
  const jsonPath = join(process.cwd(), 'public', folder, 'fotos.json');
  try {
    const data: Array<{ photo: string; title: string; description: string }> =
      JSON.parse(readFileSync(jsonPath, 'utf-8'));
    return Object.fromEntries(
      data.map(item => [item.photo, { title: item.title || undefined, description: item.description || undefined }])
    );
  } catch {
    return {};
  }
}

function getFolderCaptionsRecursive(folder: string): Record<string, CaptionEntry> {
  const root = join(process.cwd(), 'public', folder);
  const out: Record<string, CaptionEntry> = {};
  function walk(rel: string): void {
    const abs = rel ? join(root, rel) : root;
    for (const entry of readdirSync(abs, { withFileTypes: true })) {
      if (entry.isDirectory()) {
        walk(rel ? `${rel}/${entry.name}` : entry.name);
      }
    }
    try {
      const data: Array<{ photo: string; title: string; description: string }> =
        JSON.parse(readFileSync(join(abs, 'fotos.json'), 'utf-8'));
      for (const item of data) {
        const key = rel ? `${rel}/${item.photo}` : item.photo;
        out[key] = { title: item.title || undefined, description: item.description || undefined };
      }
    } catch {}
  }
  walk('');
  return out;
}

