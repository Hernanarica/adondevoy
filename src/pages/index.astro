<script>
  import fullpage from 'fullpage.js';
  import Swiper from 'swiper';
  import { Navigation, Keyboard } from 'swiper/modules';

  // ── Agregar nuevas secciones acá ──────────────────────────────
  const SECTIONS = [
    { anchor: 'van-gogh',          label: 'Van Gogh',          title: 'VAN GOGH',          sub: ''                       },
    { anchor: 'halloween',         label: 'Halloween',         title: 'HALLOWEEN',         sub: ''                       },
    { anchor: 'messi',             label: 'Messi',             title: 'MESSI',             sub: ''                       },
    { anchor: 'steve-mccurry',     label: 'Steve McCurry',     title: 'STEVE MCCURRY',     sub: ''                       },
    { anchor: 'islas-malvinas',    label: 'Islas Malvinas',    title: 'ISLAS MALVINAS',    sub: 'Cinco Cruceros'         },
    { anchor: 'trelew',            label: 'Trelew',            title: 'TRELEW',            sub: 'Tombo y Mártires'       },
    { anchor: 'martin-garcia',     label: 'Martín García',     title: 'MARTÍN GARCÍA',     sub: 'Isla'                   },
    { anchor: 'banksy',            label: 'Banksy',            title: 'BANKSY',            sub: ''                       },
    { anchor: 'mendoza',           label: 'Mendoza',           title: 'MENDOZA',           sub: 'Ayer y Hoy'             },
    { anchor: 'gaiman',            label: 'Gaiman',            title: 'GAIMAN',            sub: 'Patagonia galesa'       },
    { anchor: 'ecoparque',         label: 'Ecoparque',         title: 'ECOPARQUE',         sub: 'Buenos Aires'           },
    { anchor: 'cataratas',         label: 'Cataratas',         title: 'CATARATAS',         sub: 'Iguazú'                 },
    { anchor: 'bariloche',         label: 'Bariloche',         title: 'BARILOCHE',         sub: 'en familia'             },
    { anchor: 'lautrec',           label: 'Lautrec',           title: 'LAUTREC',           sub: ''                       },
    { anchor: 'ushuaia-1',         label: 'Ushuaia I',         title: 'USHUAIA',           sub: 'primera visita'         },
    { anchor: 'ushuaia-2',         label: 'Ushuaia II',        title: 'USHUAIA',           sub: 'segunda visita'         },
    { anchor: 'tandil',            label: 'Tandil',            title: 'TANDIL',            sub: 'Buenos Aires'           },
    { anchor: 'valadon',           label: 'Valadon',           title: 'VALADON',           sub: ''                       },
    { anchor: 'patagonia-austral', label: 'Patagonia Austral', title: 'PATAGONIA AUSTRAL', sub: ''                       },
    { anchor: 'peninsula-valdes',  label: 'Península Valdés',  title: 'PENÍNSULA VALDÉS',  sub: ''                       },
    { anchor: 'puerto-madryn',     label: 'Puerto Madryn',     title: 'PUERTO MADRYN',     sub: ''                       },
    { anchor: 'calafate',          label: 'Calafate',          title: 'CALAFATE',          sub: 'Maravillas Patagónicas' },
    { anchor: 'la-cumbrecita',     label: 'La Cumbrecita',     title: 'LA CUMBRECITA',     sub: 'Córdoba'                },
  ];
  // ─────────────────────────────────────────────────────────────

  function updateSectionUI(anchor: string): void {
    const section = SECTIONS.find(s => s.anchor === anchor);
    if (!section) return;
    const titleEl = document.getElementById('js-section-title');
    const subEl = document.getElementById('js-section-sub');
    if (titleEl) titleEl.textContent = section.title;
    if (subEl) subEl.textContent = section.sub;
    document.querySelectorAll<HTMLElement>('.section-nav__item').forEach(item => {
      item.classList.toggle('section-nav__item--active', item.dataset.anchor === anchor);
    });
  }

  function updateCounter(swiper: InstanceType<typeof Swiper>): void {
    const current = swiper.el.querySelector<HTMLElement>('.photo-gallery__counter-current');
    if (current) current.textContent = String(swiper.activeIndex + 1);
  }

  function updateIntroState(swiper: InstanceType<typeof Swiper>): void {
    swiper.el.classList.toggle('photo-gallery__carousel--intro-active', swiper.activeIndex === 0);
  }

  function makeHandlers(anchor: string) {
    return {
      init(this: InstanceType<typeof Swiper>) {
        updateCounter(this);
        updateIntroState(this);
      },
      slideChange(this: InstanceType<typeof Swiper>) {
        savedIndex[anchor] = this.activeIndex;
        updateCounter(this);
        updateIntroState(this);
      },
    };
  }

  const brand = document.querySelector<HTMLElement>('.site-header__brand');

  function animateBrandLeave(): void {
    brand?.classList.remove('site-header__brand--entering');
    brand?.classList.add('site-header__brand--leaving');
  }

  function animateBrandEnter(): void {
    brand?.classList.remove('site-header__brand--leaving');
    brand?.classList.add('site-header__brand--entering');
  }

  const savedIndex: Record<string, number> = {};
  const swipers: Record<string, InstanceType<typeof Swiper>> = {};

  for (const { anchor } of SECTIONS) {
    savedIndex[anchor] = 0;
    swipers[anchor] = new Swiper(`#swiper-${anchor}`, {
      modules: [Navigation, Keyboard],
      direction: 'horizontal',
      touchReleaseOnEdges: true,
      resistanceRatio: 0,
      navigation: { prevEl: `#prev-${anchor}`, nextEl: `#next-${anchor}` },
      keyboard: { enabled: true, onlyInViewport: true },
      a11y: { enabled: true },
      preloadImages: false,
      on: makeHandlers(anchor),
    });
    swipers[anchor].disable();
  }

  // Solo la primera sección arranca habilitada
  swipers[SECTIONS[0].anchor].enable();
  updateSectionUI(SECTIONS[0].anchor);

  new fullpage('#fullpage', {
    autoScrolling: true,
    fitToSection: true,
    navigation: false,
    anchors: SECTIONS.map(s => s.anchor),
    scrollingSpeed: 700,
    keyboardScrolling: true,
    onLeave() {
      Object.values(swipers).forEach(s => s.disable());
      animateBrandLeave();
    },
    afterLoad(_origin: unknown, destination: { anchor: string }) {
      const swiper = swipers[destination.anchor];
      swiper.enable();
      swiper.slideTo(savedIndex[destination.anchor], 0);
      updateSectionUI(destination.anchor);
      animateBrandEnter();
    },
  });

  document.querySelectorAll<HTMLButtonElement>('.section-nav__item').forEach(item => {
    item.addEventListener('click', () => {
      if (item.dataset.anchor) (window as any).fullpage_api?.moveTo(item.dataset.anchor);
    });
  });

  // ── Menú de países ────────────────────────────────────────────
  const currentCountry = 'argentina';

  const menuBtn  = document.getElementById('js-menu-btn');
  const countryNav = document.getElementById('js-country-nav');
  const backdrop = document.getElementById('js-country-nav-backdrop');

  function openMenu(): void {
    countryNav?.classList.add('is-open');
    backdrop?.classList.add('is-open');
    countryNav?.setAttribute('aria-hidden', 'false');
    menuBtn?.setAttribute('aria-expanded', 'true');
  }

  function closeMenu(): void {
    countryNav?.classList.remove('is-open');
    backdrop?.classList.remove('is-open');
    countryNav?.setAttribute('aria-hidden', 'true');
    menuBtn?.setAttribute('aria-expanded', 'false');
  }

  menuBtn?.addEventListener('click', () => {
    countryNav?.classList.contains('is-open') ? closeMenu() : openMenu();
  });
  backdrop?.addEventListener('click', closeMenu);
  document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeMenu(); });

  document.querySelector<HTMLElement>(`[data-country="${currentCountry}"]`)?.setAttribute('data-current', '');
  // ─────────────────────────────────────────────────────────────
</script>
