  Lautrec:          getFolderCaptions('Argentina/Lautrec'),
  Ushuaia1:         getFolderCaptions('Argentina/Ushuaia1'),
  Tandil:           getFolderCaptions('Argentina/Tandil'),
  Valadon:          getFolderCaptions('Argentina/Valadon'),
