---
import { readdirSync, readFileSync } from 'node:fs';
import { join } from 'node:path';

import 'fullpage.js/dist/fullpage.min.css';
import 'swiper/css';
import 'swiper/css/navigation';

import Layout from '../layouts/Layout.astro';

function getImages(folder: string): string[] {
  const dir = join(process.cwd(), 'public', folder);
  return readdirSync(dir)
    .filter(f => /\.(jpe?g|png|webp|avif|gif)$/i.test(f) && !/^00\./i.test(f))
    .sort((a, b) => a.localeCompare(b, undefined, { numeric: true, sensitivity: 'base' }));
}

interface CaptionEntry { title?: string; description?: string }

function getFolderCaptions(folder: string): Record<string, CaptionEntry> {
  const jsonPath = join(process.cwd(), 'public', folder, 'fotos.json');
  try {
    const data: Array<{ photo: string; title: string; description: string }> =
      JSON.parse(readFileSync(jsonPath, 'utf-8'));
    return Object.fromEntries(
      data.map(item => [item.photo, { title: item.title || undefined, description: item.description || undefined }])
    );
  } catch {
    return {};
  }
}

const basileaPhotos           = getImages('Europa/basilea');
const estrasburgoColmarPhotos = getImages('Europa/estrasburgo-colmar');
const breisachPhotos          = getImages('Europa/breisach');
const rinRomanticoPhotos      = getImages('Europa/rhin-romantico');
const wormsPhotos             = getImages('Europa/worms');
const heidelbergEspiraPhotos  = getImages('Europa/heidelberg-espira');
const frankfurtPhotos         = getImages('Europa/frankfurt');
const magunciaPhotos          = getImages('Europa/maguncia');
const rudesheiPhotos          = getImages('Europa/rudesheim');
const coblenzaPhotos          = getImages('Europa/coblenza');
const linzAmRheinPhotos       = getImages('Europa/linz-am-rhein');
const cochemPhotos            = getImages('Europa/cochem');
const coloniaPhotos           = getImages('Europa/colonia-bonn');
