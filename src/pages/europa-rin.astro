---
import GalleryPage from '../layouts/GalleryPage.astro';
import { getImages, getFolderCaptions, type GallerySectionData } from '../lib/gallery';

const siteBase = 'https://adondevoy.com.ar';

const sections: GallerySectionData[] = [
  { anchor: 'basilea',       folder: 'Europa/basilea',           title: 'BASILEA',       sub: 'Suiza',        label: 'Basilea',       photos: getImages('Europa/basilea'),           captions: getFolderCaptions('Europa/basilea') },
  { anchor: 'estrasburgo',   folder: 'Europa/estrasburgo-colmar', title: 'ESTRASBURGO',   sub: 'y Colmar',     label: 'Estrasburgo',   photos: getImages('Europa/estrasburgo-colmar'), captions: getFolderCaptions('Europa/estrasburgo-colmar') },
  { anchor: 'breisach',      folder: 'Europa/breisach',          title: 'BREISACH',      sub: 'Alemania',     label: 'Breisach',      photos: getImages('Europa/breisach'),          captions: getFolderCaptions('Europa/breisach') },
  { anchor: 'rin-romantico', folder: 'Europa/rhin-romantico',    title: 'RIN ROMÁNTICO', label: 'Rin Romántico', photos: getImages('Europa/rhin-romantico'),    captions: getFolderCaptions('Europa/rhin-romantico') },
  { anchor: 'worms',         folder: 'Europa/worms',             title: 'WORMS',         sub: 'Alemania',     label: 'Worms',         photos: getImages('Europa/worms'),             captions: getFolderCaptions('Europa/worms') },
  { anchor: 'heidelberg',    folder: 'Europa/heidelberg-espira', title: 'HEIDELBERG',    sub: 'y Espira',     label: 'Heidelberg',    photos: getImages('Europa/heidelberg-espira'), captions: getFolderCaptions('Europa/heidelberg-espira') },
  { anchor: 'frankfurt',     folder: 'Europa/frankfurt',         title: 'FRANKFURT',     sub: 'Alemania',     label: 'Frankfurt',     photos: getImages('Europa/frankfurt'),         captions: getFolderCaptions('Europa/frankfurt') },
  { anchor: 'maguncia',      folder: 'Europa/maguncia',          title: 'MAGUNCIA',      sub: 'Alemania',     label: 'Maguncia',      photos: getImages('Europa/maguncia'),          captions: getFolderCaptions('Europa/maguncia') },
  { anchor: 'rudesheim',     folder: 'Europa/rudesheim',         title: 'RÜDESHEIM',     sub: 'Alemania',     label: 'Rüdesheim',     photos: getImages('Europa/rudesheim'),         captions: getFolderCaptions('Europa/rudesheim') },
  { anchor: 'coblenza',      folder: 'Europa/coblenza',          title: 'COBLENZA',      sub: 'Alemania',     label: 'Coblenza',      photos: getImages('Europa/coblenza'),          captions: getFolderCaptions('Europa/coblenza') },
  { anchor: 'linz-am-rhein', folder: 'Europa/linz-am-rhein',     title: 'LINZ AM RHEIN', sub: 'Alemania',     label: 'Linz am Rhein', photos: getImages('Europa/linz-am-rhein'),     captions: getFolderCaptions('Europa/linz-am-rhein') },
  { anchor: 'cochem',        folder: 'Europa/cochem',            title: 'COCHEM',        sub: 'Alemania',     label: 'Cochem',        photos: getImages('Europa/cochem'),            captions: getFolderCaptions('Europa/cochem') },
  { anchor: 'colonia-bonn',  folder: 'Europa/colonia-bonn',      title: 'COLONIA',       sub: 'y Bonn',       label: 'Colonia',       photos: getImages('Europa/colonia-bonn'),      captions: getFolderCaptions('Europa/colonia-bonn') },
  { anchor: 'dusseldorf',    folder: 'Europa/dusseldorf',        title: 'DÜSSELDORF',    sub: 'Alemania',     label: 'Düsseldorf',    photos: getImages('Europa/dusseldorf'),        captions: getFolderCaptions('Europa/dusseldorf') },
  { anchor: 'amsterdam',     folder: 'Europa/amsterdam',         title: 'AMSTERDAM',     sub: 'Países Bajos', label: 'Amsterdam',     photos: getImages('Europa/amsterdam'),         captions: getFolderCaptions('Europa/amsterdam') },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'ImageGallery',
  name: 'Crucero por el Rin — Fotografía de viajes',
  description: 'Galería fotográfica del Crucero por el Rin: Basilea, Estrasburgo, Heidelberg, Colonia, Düsseldorf, Ámsterdam y más. Fotografías de Orlando Moure.',
  author: { '@type': 'Person', name: 'Orlando Moure', url: siteBase },
  url: `${siteBase}/europa-rin`,
};
---

<GalleryPage
  currentCountry="europa-rin"
  sections={sections}
  title="Crucero por el Rin — Fotografía de viajes"
  description="Galería fotográfica del Crucero por el Rin: Basilea, Estrasburgo, Heidelberg, Colonia, Düsseldorf, Ámsterdam y más. Fotografías de Orlando Moure."
  canonical={`${siteBase}/europa-rin`}
  ogImage={`${siteBase}/Europa/frankfurt/00.webp`}
  pageHeading="Crucero por el Rin — Fotografía de viajes"
  jsonLd={jsonLd}
/>
