  Rudesheim:         getFolderCaptions('Europa/rudesheim'),
  Coblenza:          getFolderCaptions('Europa/coblenza'),
  LinzAmRhein:       getFolderCaptions('Europa/linz-am-rhein'),
  Cochem:            getFolderCaptions('Europa/cochem'),
  Colonia:           getFolderCaptions('Europa/colonia-bonn'),
  Dusseldorf:        getFolderCaptions('Europa/dusseldorf'),
  Amsterdam:         getFolderCaptions('Europa/amsterdam'),
