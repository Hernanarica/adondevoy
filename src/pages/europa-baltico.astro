---
import { readdirSync, readFileSync } from 'node:fs';
import { join } from 'node:path';

import 'fullpage.js/dist/fullpage.min.css';
import 'swiper/css';
import 'swiper/css/navigation';

import Layout from '../layouts/Layout.astro';

function getImages(folder: string): string[] {
  const dir = join(process.cwd(), 'public', folder);
  return readdirSync(dir)
    .filter(f => /\.(jpe?g|png|webp|avif|gif)$/i.test(f) && !/^00\./i.test(f))
    .sort((a, b) => a.localeCompare(b, undefined, { numeric: true, sensitivity: 'base' }));
}

interface CaptionEntry { title?: string; description?: string }

function getFolderCaptions(folder: string): Record<string, CaptionEntry> {
  const jsonPath = join(process.cwd(), 'public', folder, 'fotos.json');
  try {
    const data: Array<{ photo: string; title: string; description: string }> =
      JSON.parse(readFileSync(jsonPath, 'utf-8'));
    return Object.fromEntries(
      data.map(item => [item.photo, { title: item.title || undefined, description: item.description || undefined }])
    );
  } catch {
    return {};
  }
}

const berlinPhotos          = getImages('Europa/berlin');
const rostockPhotos         = getImages('Europa/rostock');
const warnemuendePhotos     = getImages('Europa/warnemunde');
const marBalticoPhotos      = getImages('Europa/marbaltico');
const tallinPhotos          = getImages('Europa/tallin');
const sanPetersburgo1Photos = getImages('Europa/san-petersburgo1');
const sanPetersburgo2Photos = getImages('Europa/san-petersburgo2');
const helsinkiPhotos        = getImages('Europa/helsinki');
const estocolmoPhotos       = getImages('Europa/estocolmo');
const malmoPhotos           = getImages('Europa/malmo');
const copenhaguePhotos      = getImages('Europa/copenhague');
const vueloPhotos           = getImages('Europa/vuelo');

const captions: Record<string, Record<string, CaptionEntry>> = {
  Berlin:          getFolderCaptions('Europa/berlin'),
  Rostock:         getFolderCaptions('Europa/rostock'),
  Warnemuende:     getFolderCaptions('Europa/warnemunde'),
  MarBaltico:      getFolderCaptions('Europa/marbaltico'),
  Tallin:          getFolderCaptions('Europa/tallin'),
  SanPetersburgo1: getFolderCaptions('Europa/san-petersburgo1'),
  SanPetersburgo2: getFolderCaptions('Europa/san-petersburgo2'),
  Helsinki:        getFolderCaptions('Europa/helsinki'),
  Estocolmo:       getFolderCaptions('Europa/estocolmo'),
  Malmo:           getFolderCaptions('Europa/malmo'),
  Copenhague:      getFolderCaptions('Europa/copenhague'),
  Vuelo:           getFolderCaptions('Europa/vuelo'),
};

const currentCountry = 'europa-baltico';

const siteBase = 'https://adondevoy.com.ar';
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'ImageGallery',
  name: 'Crucero por el Báltico — Fotografía de viajes',
  description: 'Galería fotográfica del Crucero por el Báltico: Estocolmo, Helsinki, San Petersburgo, Tallin, Copenhague, Berlín y más. Fotografías de Orlando Moure.',
  author: { '@type': 'Person', name: 'Orlando Moure', url: siteBase },
  url: `${siteBase}/europa-baltico`,
