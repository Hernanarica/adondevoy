---
import GalleryPage from '../layouts/GalleryPage.astro';
import { getImages, getFolderCaptions, type GallerySectionData } from '../lib/gallery';

const siteBase = 'https://adondevoy.com.ar';

const sections: GallerySectionData[] = [
  { anchor: 'berlin',            folder: 'Europa/berlin',           title: 'BERLÍN',          sub: 'Alemania',       label: 'Berlín',             photos: getImages('Europa/berlin'),           captions: getFolderCaptions('Europa/berlin') },
  { anchor: 'rostock',           folder: 'Europa/rostock',          title: 'ROSTOCK',         sub: 'Alemania',       label: 'Rostock',            photos: getImages('Europa/rostock'),          captions: getFolderCaptions('Europa/rostock') },
  { anchor: 'warnemunde',        folder: 'Europa/warnemunde',       title: 'WARNEMÜNDE',      sub: 'Alemania',       label: 'Warnemünde',         photos: getImages('Europa/warnemunde'),       captions: getFolderCaptions('Europa/warnemunde') },
  { anchor: 'mar-baltico',       folder: 'Europa/marbaltico',       title: 'MAR BÁLTICO',                            label: 'Mar Báltico',        photos: getImages('Europa/marbaltico'),       captions: getFolderCaptions('Europa/marbaltico') },
  { anchor: 'tallin',            folder: 'Europa/tallin',           title: 'TALLIN',          sub: 'Estonia',        label: 'Tallin',             photos: getImages('Europa/tallin'),           captions: getFolderCaptions('Europa/tallin') },
  { anchor: 'san-petersburgo-1', folder: 'Europa/san-petersburgo1', title: 'SAN PETERSBURGO', sub: 'primera visita', label: 'San Petersburgo I',  photos: getImages('Europa/san-petersburgo1'), captions: getFolderCaptions('Europa/san-petersburgo1') },
  { anchor: 'san-petersburgo-2', folder: 'Europa/san-petersburgo2', title: 'SAN PETERSBURGO', sub: 'segunda visita', label: 'San Petersburgo II', photos: getImages('Europa/san-petersburgo2'), captions: getFolderCaptions('Europa/san-petersburgo2') },
  { anchor: 'helsinki',          folder: 'Europa/helsinki',         title: 'HELSINKI',        sub: 'Finlandia',      label: 'Helsinki',           photos: getImages('Europa/helsinki'),         captions: getFolderCaptions('Europa/helsinki') },
  { anchor: 'estocolmo',         folder: 'Europa/estocolmo',        title: 'ESTOCOLMO',       sub: 'Suecia',         label: 'Estocolmo',          photos: getImages('Europa/estocolmo'),        captions: getFolderCaptions('Europa/estocolmo') },
  { anchor: 'malmo',             folder: 'Europa/malmo',            title: 'MALMÖ',           sub: 'Suecia',         label: 'Malmö',              photos: getImages('Europa/malmo'),            captions: getFolderCaptions('Europa/malmo') },
  { anchor: 'copenhague',        folder: 'Europa/copenhague',       title: 'COPENHAGUE',      sub: 'Dinamarca',      label: 'Copenhague',         photos: getImages('Europa/copenhague'),       captions: getFolderCaptions('Europa/copenhague') },
  { anchor: 'vuelo',             folder: 'Europa/vuelo',            title: 'VUELO',                                  label: 'Vuelo',              photos: getImages('Europa/vuelo'),            captions: getFolderCaptions('Europa/vuelo') },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'ImageGallery',
  name: 'Crucero por el Báltico — Fotografía de viajes',
  description: 'Galería fotográfica del Crucero por el Báltico: Estocolmo, Helsinki, San Petersburgo, Tallin, Copenhague, Berlín y más. Fotografías de Orlando Moure.',
  author: { '@type': 'Person', name: 'Orlando Moure', url: siteBase },
  url: `${siteBase}/europa-baltico`,
};
---

<GalleryPage
  currentCountry="europa-baltico"
  sections={sections}
  title="Crucero por el Báltico — Fotografía de viajes"
  description="Galería fotográfica del Crucero por el Báltico: Estocolmo, Helsinki, San Petersburgo, Tallin, Copenhague, Berlín y más. Fotografías de Orlando Moure."
  canonical={`${siteBase}/europa-baltico`}
  pageHeading="Crucero por el Báltico — Fotografía de viajes"
  jsonLd={jsonLd}
/>
