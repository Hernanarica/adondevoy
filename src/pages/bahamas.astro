---
import GalleryPage from '../layouts/GalleryPage.astro';
import { getImages, getFolderCaptions, type GallerySectionData } from '../lib/gallery';

const siteBase = 'https://adondevoy.com.ar';

const sections: GallerySectionData[] = [
  {
    anchor: 'bahamas',
    folder: 'Bahamas/Bahamas',
    title: 'BAHAMAS',
    sub: 'en familia',
    label: 'Bahamas',
    body: 'Una escapada familiar que comenzó en la vibrante Miami y nos llevó hasta Nassau, la colorida capital de las Bahamas. Playas de arena blanca, aguas de un azul imposible, historia pirata y una cultura caribeña única esperaban a la familia en estas paradisíacas islas del Atlántico norte.',
    photos: getImages('Bahamas/Bahamas'),
    captions: getFolderCaptions('Bahamas/Bahamas'),
  },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'ImageGallery',
  name: 'Bahamas — Fotografía de viajes',
  description: 'Galería fotográfica de Bahamas: paisajes del Caribe. Fotografías de Orlando Moure.',
  author: { '@type': 'Person', name: 'Orlando Moure', url: siteBase },
  url: `${siteBase}/bahamas`,
};
---

<GalleryPage
  currentCountry="bahamas"
  sections={sections}
  title="Bahamas — Fotografía de viajes"
  description="Galería fotográfica de Bahamas: paisajes del Caribe. Fotografías de Orlando Moure."
  canonical={`${siteBase}/bahamas`}
  ogImage={`${siteBase}/Bahamas/Bahamas/00.webp`}
  pageHeading="Bahamas — Fotografía de viajes"
  jsonLd={jsonLd}
/>
