---
import GalleryPage from '../layouts/GalleryPage.astro';
import { getImages, getFolderCaptions, type GallerySectionData } from '../lib/gallery';

const siteBase = 'https://adondevoy.com.ar';

const sections: GallerySectionData[] = [
  { anchor: 'andalucia',      folder: 'Europa/Andalucia',                          title: 'ANDALUCÍA',       sub: 'España',  label: 'Andalucía',       photos: getImages('Europa/Andalucia'),                          captions: getFolderCaptions('Europa/Andalucia') },
  { anchor: 'paris-dia-1',    folder: 'Europa/paris/dia1',                         title: 'PARÍS',           sub: 'día 1',   label: 'París · día 1',   photos: getImages('Europa/paris/dia1'),                         captions: getFolderCaptions('Europa/paris/dia1') },
  { anchor: 'paris-dia-2',    folder: 'Europa/paris/dia2',                         title: 'PARÍS',           sub: 'día 2',   label: 'París · día 2',   photos: getImages('Europa/paris/dia2'),                         captions: getFolderCaptions('Europa/paris/dia2') },
  { anchor: 'paris-dia-3',    folder: 'Europa/paris/dia3',                         title: 'PARÍS',           sub: 'día 3',   label: 'París · día 3',   photos: getImages('Europa/paris/dia3'),                         captions: getFolderCaptions('Europa/paris/dia3') },
  { anchor: 'paris-dia-4',    folder: 'Europa/paris/dia4',                         title: 'PARÍS',           sub: 'día 4',   label: 'París · día 4',   photos: getImages('Europa/paris/dia4'),                         captions: getFolderCaptions('Europa/paris/dia4') },
  { anchor: 'paris-dia-5',    folder: 'Europa/paris/dia5',                         title: 'PARÍS',           sub: 'día 5',   label: 'París · día 5',   photos: getImages('Europa/paris/dia5'),                         captions: getFolderCaptions('Europa/paris/dia5') },
  { anchor: 'paris-dia-6',    folder: 'Europa/paris/dia6',                         title: 'PARÍS',           sub: 'día 6',   label: 'París · día 6',   photos: getImages('Europa/paris/dia6'),                         captions: getFolderCaptions('Europa/paris/dia6') },
  { anchor: 'paris-dia-7',    folder: 'Europa/paris/dia7',                         title: 'PARÍS',           sub: 'día 7',   label: 'París · día 7',   photos: getImages('Europa/paris/dia7'),                         captions: getFolderCaptions('Europa/paris/dia7') },
  { anchor: 'paris-dia-8',    folder: 'Europa/paris/dia8',                         title: 'PARÍS',           sub: 'día 8',   label: 'París · día 8',   photos: getImages('Europa/paris/dia8'),                         captions: getFolderCaptions('Europa/paris/dia8') },
  { anchor: 'lille',          folder: 'Europa/lille',                              title: 'LILLE',           sub: 'Francia', label: 'Lille',           photos: getImages('Europa/lille'),                              captions: getFolderCaptions('Europa/lille') },
  { anchor: 'bruselas',       folder: 'Europa/bruselas',                           title: 'BRUSELAS',        sub: 'Bélgica', label: 'Bruselas',        photos: getImages('Europa/bruselas'),                           captions: getFolderCaptions('Europa/bruselas') },
  { anchor: 'brujas',         folder: 'Europa/brujas',                             title: 'BRUJAS',          sub: 'Bélgica', label: 'Brujas',          photos: getImages('Europa/brujas'),                             captions: getFolderCaptions('Europa/brujas') },
  { anchor: 'lucerna',        folder: 'Europa/Lucerna',                            title: 'LUCERNA',         sub: 'Suiza',   label: 'Lucerna',         photos: getImages('Europa/Lucerna'),                            captions: getFolderCaptions('Europa/Lucerna') },
  { anchor: 'swiss-diamond',  folder: 'Europa/alojamiento/SwissDiamond-Politours', title: 'SWISS DIAMOND',   sub: 'Hotel',   label: 'Swiss Diamond',   photos: getImages('Europa/alojamiento/SwissDiamond-Politours'), captions: getFolderCaptions('Europa/alojamiento/SwissDiamond-Politours') },
  { anchor: 'swiss-pearl',    folder: 'Europa/alojamiento/SwissPearl-Politours',   title: 'SWISS PEARL',     sub: 'Hotel',   label: 'Swiss Pearl',     photos: getImages('Europa/alojamiento/SwissPearl-Politours'),   captions: getFolderCaptions('Europa/alojamiento/SwissPearl-Politours') },
  { anchor: 'europa-noche-2', folder: 'Europa/Europa-de-Noche2',                   title: 'EUROPA DE NOCHE',                 label: 'Europa de Noche', photos: getImages('Europa/Europa-de-Noche2'),                   captions: getFolderCaptions('Europa/Europa-de-Noche2') },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'ImageGallery',
  name: 'Europa Occidental — Fotografía de viajes',
  description: 'Galería fotográfica de Europa Occidental: París, Lucerna, Andalucía, Brujas, Bruselas y más. Fotografías de Orlando Moure.',
  author: { '@type': 'Person', name: 'Orlando Moure', url: siteBase },
  url: `${siteBase}/europa-oeste`,
};
---

<GalleryPage
  currentCountry="europa-oeste"
  sections={sections}
  title="Europa Occidental — Fotografía de viajes"
  description="Galería fotográfica de Europa Occidental: París, Lucerna, Andalucía, Brujas, Bruselas y más. Fotografías de Orlando Moure."
  canonical={`${siteBase}/europa-oeste`}
  ogImage={`${siteBase}/Europa/paris/dia2/00.webp`}
  pageHeading="Europa Occidental — Fotografía de viajes"
  jsonLd={jsonLd}
/>
