  ParisDia7:    getFolderCaptions('Europa/paris/dia7'),
  ParisDia8:    getFolderCaptions('Europa/paris/dia8'),
  Lille:        getFolderCaptions('Europa/lille'),
  Bruselas:     getFolderCaptions('Europa/bruselas'),
  Brujas:       getFolderCaptions('Europa/brujas'),
  Lucerna:      getFolderCaptions('Europa/Lucerna'),
