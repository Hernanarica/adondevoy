---
import { readdirSync, readFileSync } from 'node:fs';
import { join } from 'node:path';

import 'fullpage.js/dist/fullpage.min.css';
import 'swiper/css';
import 'swiper/css/navigation';

import Layout from '../layouts/Layout.astro';

function getImages(folder: string): string[] {
  const dir = join(process.cwd(), 'public', folder);
  return readdirSync(dir)
    .filter(f => /\.(jpe?g|png|webp|avif|gif)$/i.test(f) && !/^00\./i.test(f))
    .sort((a, b) => a.localeCompare(b, undefined, { numeric: true, sensitivity: 'base' }));
}

interface CaptionEntry { title?: string; description?: string }

function getFolderCaptions(folder: string): Record<string, CaptionEntry> {
  const jsonPath = join(process.cwd(), 'public', folder, 'fotos.json');
  try {
    const data: Array<{ photo: string; title: string; description: string }> =
      JSON.parse(readFileSync(jsonPath, 'utf-8'));
    return Object.fromEntries(
      data.map(item => [item.photo, { title: item.title || undefined, description: item.description || undefined }])
    );
  } catch {
    return {};
  }
}

const passauPhotos     = getImages('Europa/passau');
const linzPhotos       = getImages('Europa/linz');
const melkPhotos       = getImages('Europa/melk');
const durnsteinPhotos  = getImages('Europa/durnstein');
const salzburgoPhotos  = getImages('Europa/salzburgo');
const vienaPhotos      = getImages('Europa/viena');
const bratislavaPhotos = getImages('Europa/bratislava');
const pragaPhotos      = getImages('Europa/praga');
const budapestPhotos   = getImages('Europa/budapest');
const esztergomPhotos  = getImages('Europa/esztergom');
const szentendrePhotos = getImages('Europa/szentendre');

const captions: Record<string, Record<string, CaptionEntry>> = {
  Passau:     getFolderCaptions('Europa/passau'),
  Linz:       getFolderCaptions('Europa/linz'),
  Melk:       getFolderCaptions('Europa/melk'),
  Durnstein:  getFolderCaptions('Europa/durnstein'),
  Salzburgo:  getFolderCaptions('Europa/salzburgo'),
  Viena:      getFolderCaptions('Europa/viena'),
  Bratislava: getFolderCaptions('Europa/bratislava'),
  Praga:      getFolderCaptions('Europa/praga'),
  Budapest:   getFolderCaptions('Europa/budapest'),
  Esztergom:  getFolderCaptions('Europa/esztergom'),
  Szentendre: getFolderCaptions('Europa/szentendre'),
