---
import GalleryPage from '../layouts/GalleryPage.astro';
import { getImages, getFolderCaptions, type GallerySectionData } from '../lib/gallery';

const siteBase = 'https://adondevoy.com.ar';

const sections: GallerySectionData[] = [
  { anchor: 'passau',     folder: 'Europa/passau',     title: 'PASSAU',     sub: 'Alemania',        label: 'Passau',     photos: getImages('Europa/passau'),     captions: getFolderCaptions('Europa/passau') },
  { anchor: 'linz',       folder: 'Europa/linz',       title: 'LINZ',       sub: 'Austria',         label: 'Linz',       photos: getImages('Europa/linz'),       captions: getFolderCaptions('Europa/linz') },
  { anchor: 'melk',       folder: 'Europa/melk',       title: 'MELK',       sub: 'Austria',         label: 'Melk',       photos: getImages('Europa/melk'),       captions: getFolderCaptions('Europa/melk') },
  { anchor: 'durnstein',  folder: 'Europa/durnstein',  title: 'DÜRNSTEIN',  sub: 'Austria',         label: 'Dürnstein',  photos: getImages('Europa/durnstein'),  captions: getFolderCaptions('Europa/durnstein') },
  { anchor: 'salzburgo',  folder: 'Europa/salzburgo',  title: 'SALZBURGO',  sub: 'Austria',         label: 'Salzburgo',  photos: getImages('Europa/salzburgo'),  captions: getFolderCaptions('Europa/salzburgo') },
  { anchor: 'viena',      folder: 'Europa/viena',      title: 'VIENA',      sub: 'Austria',         label: 'Viena',      photos: getImages('Europa/viena'),      captions: getFolderCaptions('Europa/viena') },
  { anchor: 'bratislava', folder: 'Europa/bratislava', title: 'BRATISLAVA', sub: 'Eslovaquia',      label: 'Bratislava', photos: getImages('Europa/bratislava'), captions: getFolderCaptions('Europa/bratislava') },
  { anchor: 'praga',      folder: 'Europa/praga',      title: 'PRAGA',      sub: 'República Checa', label: 'Praga',      photos: getImages('Europa/praga'),      captions: getFolderCaptions('Europa/praga') },
  { anchor: 'budapest',   folder: 'Europa/budapest',   title: 'BUDAPEST',   sub: 'Hungría',         label: 'Budapest',   photos: getImages('Europa/budapest'),   captions: getFolderCaptions('Europa/budapest') },
  { anchor: 'esztergom',  folder: 'Europa/esztergom',  title: 'ESZTERGOM',  sub: 'Hungría',         label: 'Esztergom',  photos: getImages('Europa/esztergom'),  captions: getFolderCaptions('Europa/esztergom') },
  { anchor: 'szentendre', folder: 'Europa/szentendre', title: 'SZENTENDRE', sub: 'Hungría',         label: 'Szentendre', photos: getImages('Europa/szentendre'), captions: getFolderCaptions('Europa/szentendre') },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'ImageGallery',
  name: 'Crucero por el Danubio — Fotografía de viajes',
  description: 'Galería fotográfica del Crucero por el Danubio: Passau, Linz, Viena, Bratislava, Budapest, Salzburgo y más. Fotografías de Orlando Moure.',
  author: { '@type': 'Person', name: 'Orlando Moure', url: siteBase },
  url: `${siteBase}/europa-danubio`,
};
---

<GalleryPage
  currentCountry="europa-danubio"
  sections={sections}
  title="Crucero por el Danubio — Fotografía de viajes"
  description="Galería fotográfica del Crucero por el Danubio: Passau, Linz, Viena, Bratislava, Budapest, Salzburgo y más. Fotografías de Orlando Moure."
  canonical={`${siteBase}/europa-danubio`}
  pageHeading="Crucero por el Danubio — Fotografía de viajes"
  jsonLd={jsonLd}
/>
