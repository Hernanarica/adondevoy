---
import GalleryPage from '../layouts/GalleryPage.astro';
import { getImages, getFolderCaptions, type GallerySectionData } from '../lib/gallery';

const siteBase = 'https://adondevoy.com.ar';

const sections: GallerySectionData[] = [
  { anchor: 'partida',       folder: 'Europa/españa/01-partida',      title: 'PARTIDA',       sub: 'hacia España',  label: 'Partida',       photos: getImages('Europa/españa/01-partida'),      captions: getFolderCaptions('Europa/españa/01-partida') },
  { anchor: 'madrid',        folder: 'Europa/españa/02-madrid',       title: 'MADRID',        sub: 'España',        label: 'Madrid',        photos: getImages('Europa/españa/02-madrid'),       captions: getFolderCaptions('Europa/españa/02-madrid') },
  { anchor: 'zaragoza',      folder: 'Europa/españa/03-zaragoza',     title: 'ZARAGOZA',      sub: 'España',        label: 'Zaragoza',      photos: getImages('Europa/españa/03-zaragoza'),     captions: getFolderCaptions('Europa/españa/03-zaragoza') },
  { anchor: 'san-sebastian', folder: 'Europa/españa/04-sansebastian', title: 'SAN SEBASTIÁN', sub: 'País Vasco',    label: 'San Sebastián', photos: getImages('Europa/españa/04-sansebastian'), captions: getFolderCaptions('Europa/españa/04-sansebastian') },
  { anchor: 'bilbao',        folder: 'Europa/españa/05-bilbao',       title: 'BILBAO',        sub: 'País Vasco',    label: 'Bilbao',        photos: getImages('Europa/españa/05-bilbao'),       captions: getFolderCaptions('Europa/españa/05-bilbao') },
  { anchor: 'santander',     folder: 'Europa/españa/06-santander',    title: 'SANTANDER',     sub: 'Cantabria',     label: 'Santander',     photos: getImages('Europa/españa/06-santander'),    captions: getFolderCaptions('Europa/españa/06-santander') },
  { anchor: 'santillana',    folder: 'Europa/españa/07-santillana',   title: 'SANTILLANA',    sub: 'Cantabria',     label: 'Santillana',    photos: getImages('Europa/españa/07-santillana'),   captions: getFolderCaptions('Europa/españa/07-santillana') },
  { anchor: 'picos',         folder: 'Europa/españa/08-picos',        title: 'PICOS',         sub: 'de Europa',     label: 'Picos',         photos: getImages('Europa/españa/08-picos'),        captions: getFolderCaptions('Europa/españa/08-picos') },
  { anchor: 'covadonga',     folder: 'Europa/españa/09-covadonga',    title: 'COVADONGA',     sub: 'Asturias',      label: 'Covadonga',     photos: getImages('Europa/españa/09-covadonga'),    captions: getFolderCaptions('Europa/españa/09-covadonga') },
  { anchor: 'asturias',      folder: 'Europa/españa/10-asturias',     title: 'ASTURIAS',      sub: 'España',        label: 'Asturias',      photos: getImages('Europa/españa/10-asturias'),     captions: getFolderCaptions('Europa/españa/10-asturias') },
  { anchor: 'coruna',        folder: 'Europa/españa/11-coruna',       title: 'A CORUÑA',      sub: 'Galicia',       label: 'A Coruña',      photos: getImages('Europa/españa/11-coruna'),       captions: getFolderCaptions('Europa/españa/11-coruna') },
  { anchor: 'santiago',      folder: 'Europa/españa/12-santiago',     title: 'SANTIAGO',      sub: 'de Compostela', label: 'Santiago',      photos: getImages('Europa/españa/12-santiago'),     captions: getFolderCaptions('Europa/españa/12-santiago') },
  { anchor: 'vigo',          folder: 'Europa/españa/13-vigo',         title: 'VIGO',          sub: 'Galicia',       label: 'Vigo',          photos: getImages('Europa/españa/13-vigo'),         captions: getFolderCaptions('Europa/españa/13-vigo') },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'ImageGallery',
  name: 'España — Fotografía de viajes',
  description: 'Galería fotográfica de España: Madrid, País Vasco, Cantabria, Asturias, Galicia y más. Fotografías de Orlando Moure.',
  author: { '@type': 'Person', name: 'Orlando Moure', url: siteBase },
  url: `${siteBase}/espana`,
};
---

<GalleryPage
  currentCountry="espana"
  sections={sections}
  title="España — Fotografía de viajes"
  description="Galería fotográfica de España: Madrid, País Vasco, Cantabria, Asturias, Galicia y más. Fotografías de Orlando Moure."
  canonical={`${siteBase}/espana`}
  ogImage={`${siteBase}/Europa/españa/02-madrid/1-EmperadorGranVia.webp`}
  pageHeading="España — Fotografía de viajes"
  jsonLd={jsonLd}
/>
