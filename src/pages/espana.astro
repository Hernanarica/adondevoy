  Santillana:   getFolderCaptions('Europa/españa/07-santillana'),
  Picos:        getFolderCaptions('Europa/españa/08-picos'),
  Covadonga:    getFolderCaptions('Europa/españa/09-covadonga'),
  Asturias:     getFolderCaptions('Europa/españa/10-asturias'),
  Coruna:       getFolderCaptions('Europa/españa/11-coruna'),
  Santiago:     getFolderCaptions('Europa/españa/12-santiago'),
  Vigo:         getFolderCaptions('Europa/españa/13-vigo'),
