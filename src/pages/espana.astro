---
import { readdirSync, readFileSync } from 'node:fs';
import { join } from 'node:path';

import 'fullpage.js/dist/fullpage.min.css';
import 'swiper/css';
import 'swiper/css/navigation';

import Layout from '../layouts/Layout.astro';

function getImages(folder: string): string[] {
  const dir = join(process.cwd(), 'public', folder);
  return readdirSync(dir)
    .filter(f => /\.(jpe?g|png|webp|avif|gif)$/i.test(f) && !/^00\./i.test(f))
    .sort((a, b) => a.localeCompare(b, undefined, { numeric: true, sensitivity: 'base' }));
}

interface CaptionEntry { title?: string; description?: string }

function getFolderCaptions(folder: string): Record<string, CaptionEntry> {
  const jsonPath = join(process.cwd(), 'public', folder, 'fotos.json');
  try {
    const data: Array<{ photo: string; title: string; description: string }> =
      JSON.parse(readFileSync(jsonPath, 'utf-8'));
    return Object.fromEntries(
      data.map(item => [item.photo, { title: item.title || undefined, description: item.description || undefined }])
    );
  } catch {
    return {};
  }
}

const partidaPhotos      = getImages('Europa/españa/01-partida');
const madridPhotos       = getImages('Europa/españa/02-madrid');
const zaragozaPhotos     = getImages('Europa/españa/03-zaragoza');
const sanSebastianPhotos = getImages('Europa/españa/04-sansebastian');
const bilbaoPhotos       = getImages('Europa/españa/05-bilbao');
const santanderPhotos    = getImages('Europa/españa/06-santander');
const santillanaPhotos   = getImages('Europa/españa/07-santillana');
const picosPhotos        = getImages('Europa/españa/08-picos');
const covadongaPhotos    = getImages('Europa/españa/09-covadonga');
const asturiasPhotos     = getImages('Europa/españa/10-asturias');
const corunaPhotos       = getImages('Europa/españa/11-coruna');
const santiagoPhotos     = getImages('Europa/españa/12-santiago');
const vigoPhotos         = getImages('Europa/españa/13-vigo');

