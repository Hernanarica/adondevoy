---
import GalleryPage from '../layouts/GalleryPage.astro';
import { getImages, getFolderCaptions, type GallerySectionData } from '../lib/gallery';

const siteBase = 'https://adondevoy.com.ar';

const sections: GallerySectionData[] = [
  { anchor: 'viana-braga', folder: 'Europa/portugal/14-viana-braga', title: 'VIANA · BRAGA', sub: 'Portugal', label: 'Viana · Braga', photos: getImages('Europa/portugal/14-viana-braga'), captions: getFolderCaptions('Europa/portugal/14-viana-braga') },
  { anchor: 'oporto', folder: 'Europa/portugal/15-oporto', title: 'OPORTO', sub: 'Portugal', label: 'Oporto', photos: getImages('Europa/portugal/15-oporto'), captions: getFolderCaptions('Europa/portugal/15-oporto') },
  { anchor: 'coimbra', folder: 'Europa/portugal/16-coimbra', title: 'COIMBRA', sub: 'Portugal', label: 'Coimbra', photos: getImages('Europa/portugal/16-coimbra'), captions: getFolderCaptions('Europa/portugal/16-coimbra') },
  { anchor: 'fatima', folder: 'Europa/portugal/17-fatima', title: 'FÁTIMA', sub: 'Portugal', label: 'Fátima', photos: getImages('Europa/portugal/17-fatima'), captions: getFolderCaptions('Europa/portugal/17-fatima') },
  { anchor: 'lisboa', folder: 'Europa/portugal/18-lisboa', title: 'LISBOA', sub: 'Portugal', label: 'Lisboa', photos: getImages('Europa/portugal/18-lisboa'), captions: getFolderCaptions('Europa/portugal/18-lisboa') },
  { anchor: 'caceres', folder: 'Europa/portugal/19-caceres', title: 'CÁCERES', sub: 'Extremadura', label: 'Cáceres', photos: getImages('Europa/portugal/19-caceres'), captions: getFolderCaptions('Europa/portugal/19-caceres') },
  { anchor: 'regreso', folder: 'Europa/portugal/20-regreso', title: 'REGRESO', sub: 'hacia casa', label: 'Regreso', photos: getImages('Europa/portugal/20-regreso'), captions: getFolderCaptions('Europa/portugal/20-regreso') },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'ImageGallery',
  name: 'Portugal — Fotografía de viajes',
  description: 'Galería fotográfica de Portugal: Viana do Castelo, Oporto, Coimbra, Fátima, Lisboa y más. Fotografías de Orlando Moure.',
  author: { '@type': 'Person', name: 'Orlando Moure', url: siteBase },
  url: `${siteBase}/portugal`,
};
---

<GalleryPage
  currentCountry="portugal"
  sections={sections}
  title="Portugal — Fotografía de viajes"
  description="Galería fotográfica de Portugal: Viana do Castelo, Oporto, Coimbra, Fátima, Lisboa y más. Fotografías de Orlando Moure."
  canonical={`${siteBase}/portugal`}
  ogImage={`${siteBase}/Europa/portugal/18-lisboa/1-HotelLutecia.webp`}
  pageHeading="Portugal — Fotografía de viajes"
  jsonLd={jsonLd}
/>
