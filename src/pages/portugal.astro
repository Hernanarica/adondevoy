---
import { readdirSync, readFileSync } from 'node:fs';
import { join } from 'node:path';

import 'fullpage.js/dist/fullpage.min.css';
import 'swiper/css';
import 'swiper/css/navigation';

import Layout from '../layouts/Layout.astro';

function getImages(folder: string): string[] {
  const dir = join(process.cwd(), 'public', folder);
  return readdirSync(dir)
    .filter(f => /\.(jpe?g|png|webp|avif|gif)$/i.test(f) && !/^00\./i.test(f))
    .sort((a, b) => a.localeCompare(b, undefined, { numeric: true, sensitivity: 'base' }));
}

interface CaptionEntry { title?: string; description?: string }

function getFolderCaptions(folder: string): Record<string, CaptionEntry> {
  const jsonPath = join(process.cwd(), 'public', folder, 'fotos.json');
  try {
    const data: Array<{ photo: string; title: string; description: string }> =
      JSON.parse(readFileSync(jsonPath, 'utf-8'));
    return Object.fromEntries(
      data.map(item => [item.photo, { title: item.title || undefined, description: item.description || undefined }])
    );
  } catch {
    return {};
  }
}

const vianaPhotos   = getImages('Europa/portugal/14-viana-braga');
const oportoPhotos  = getImages('Europa/portugal/15-oporto');
const coimbraPhotos = getImages('Europa/portugal/16-coimbra');
const fatimaPhotos  = getImages('Europa/portugal/17-fatima');
const lisboaPhotos  = getImages('Europa/portugal/18-lisboa');
const caceresPhotos = getImages('Europa/portugal/19-caceres');
const regresoPhotos = getImages('Europa/portugal/20-regreso');

const captions: Record<string, Record<string, CaptionEntry>> = {
  Viana:   getFolderCaptions('Europa/portugal/14-viana-braga'),
  Oporto:  getFolderCaptions('Europa/portugal/15-oporto'),
  Coimbra: getFolderCaptions('Europa/portugal/16-coimbra'),
  Fatima:  getFolderCaptions('Europa/portugal/17-fatima'),
  Lisboa:  getFolderCaptions('Europa/portugal/18-lisboa'),
  Caceres: getFolderCaptions('Europa/portugal/19-caceres'),
  Regreso: getFolderCaptions('Europa/portugal/20-regreso'),
};

const currentCountry = 'portugal';

const siteBase = 'https://adondevoy.com.ar';
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'ImageGallery',
  name: 'Portugal — Fotografía de viajes',
  description: 'Galería fotográfica de Portugal: Viana do Castelo, Oporto, Coimbra, Fátima, Lisboa y más. Fotografías de Orlando Moure.',
  author: { '@type': 'Person', name: 'Orlando Moure', url: siteBase },
  url: `${siteBase}/portugal`,
};
---

