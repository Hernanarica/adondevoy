---
import 'fullpage.js/dist/fullpage.min.css';
import 'swiper/css';

import Layout from './Layout.astro';
import CountryNav from '../components/CountryNav.astro';
import GallerySection from '../components/GallerySection.astro';
import type { GallerySectionData } from '../lib/gallery';

interface Props {
  sections: GallerySectionData[];
  currentCountry: string;
  title?: string;
  description?: string;
  ogImage?: string;
  canonical?: string;
  pageHeading?: string;
  jsonLd?: object;
}

const {
  sections,
  currentCountry,
  title,
  description,
  ogImage,
  canonical,
  pageHeading,
  jsonLd,
} = Astro.props;

const first = sections[0];
---

<Layout
  title={title}
  description={description}
  ogImage={ogImage}
  canonical={canonical}
  pageHeading={pageHeading}
  jsonLd={jsonLd}
>
  <header class="site-header" id="js-site-header">
    <div class="site-header__brand">
      <span class="site-header__title" id="js-section-title">{first?.title}</span>
      <span class="site-header__sub" id="js-section-sub">{first?.sub ?? ''}</span>
    </div>
    <button class="site-header__menu-btn" id="js-menu-btn" aria-label="Menú" aria-expanded="false">
      <span></span>
      <span></span>
      <span></span>
    </button>
  </header>

  <CountryNav currentCountry={currentCountry} />

  <div id="fullpage" class="photo-gallery">
    {sections.map(s => <GallerySection {...s} />)}
  </div>

  <nav class="section-nav" aria-label="Secciones">
    {sections.map((s, i) => (
      <button
        class:list={['section-nav__item', i === 0 && 'section-nav__item--active']}
        data-anchor={s.anchor}
        data-label={s.label ?? s.title}
        aria-label={`Ir a ${s.label ?? s.title}`}
      ></button>
    ))}
  </nav>
</Layout>

<script>
  import fullpage from 'fullpage.js';
  import Swiper from 'swiper';
  import { Keyboard } from 'swiper/modules';

  const sectionEls = Array.from(
    document.querySelectorAll<HTMLElement>('.photo-gallery__section')
  );
  const anchors = sectionEls.map(el => el.dataset.anchor!);
  const meta: Record<string, { title: string; sub: string }> = {};
  for (const el of sectionEls) {
    meta[el.dataset.anchor!] = {
      title: el.dataset.title ?? '',
      sub: el.dataset.sub ?? '',
    };
  }

  const titleEl = document.getElementById('js-section-title');
  const subEl = document.getElementById('js-section-sub');
  const brand = document.querySelector<HTMLElement>('.site-header__brand');

  function updateSectionUI(anchor: string): void {
    const m = meta[anchor];
    if (!m) return;
    if (titleEl) titleEl.textContent = m.title;
    if (subEl) subEl.textContent = m.sub;
    document.querySelectorAll<HTMLElement>('.section-nav__item').forEach(item => {
      item.classList.toggle('section-nav__item--active', item.dataset.anchor === anchor);
    });
  }

  // El footer (caption + controles) está FUERA del swiper, fijo a nivel viewport.
  function viewportOf(swiper: InstanceType<typeof Swiper>): HTMLElement | null {
    return swiper.el.parentElement;
  }

  function updateCounter(swiper: InstanceType<typeof Swiper>): void {
    const current = viewportOf(swiper)?.querySelector<HTMLElement>('.photo-gallery__counter-current');
    if (current) current.textContent = String(swiper.activeIndex + 1);
  }

  function updateCaption(swiper: InstanceType<typeof Swiper>): void {
    const captionEl = viewportOf(swiper)?.querySelector<HTMLElement>('.photo-gallery__caption');
    if (!captionEl) return;
    const slide = swiper.slides[swiper.activeIndex] as HTMLElement | undefined;
    const title = slide?.getAttribute('data-caption-title') ?? '';
    const desc = slide?.getAttribute('data-caption-desc') ?? '';
    captionEl.replaceChildren();
    if (title) {
      const t = document.createElement('span');
      t.className = 'photo-gallery__caption-title';
      t.textContent = title;
      captionEl.appendChild(t);
    }
    if (desc) {
      const d = document.createElement('span');
      d.className = 'photo-gallery__caption-desc';
      d.textContent = desc;
      captionEl.appendChild(d);
    }
  }

  function updateIntroState(swiper: InstanceType<typeof Swiper>): void {
    viewportOf(swiper)?.classList.toggle('photo-gallery__viewport--intro-active', swiper.activeIndex === 0);
  }

  function refreshControls(swiper: InstanceType<typeof Swiper>): void {
    updateCounter(swiper);
    updateCaption(swiper);
    updateIntroState(swiper);
  }

  function animateBrandLeave(): void {
    brand?.classList.remove('site-header__brand--entering');
    brand?.classList.add('site-header__brand--leaving');
  }

  function animateBrandEnter(): void {
    brand?.classList.remove('site-header__brand--leaving');
    brand?.classList.add('site-header__brand--entering');
  }

  const savedIndex: Record<string, number> = {};
  const swipers: Record<string, InstanceType<typeof Swiper>> = {};

  for (const anchor of anchors) {
    savedIndex[anchor] = 0;
    const swiper = new Swiper(`#swiper-${anchor}`, {
      modules: [Keyboard],
      direction: 'horizontal',
      touchReleaseOnEdges: true,
      resistanceRatio: 0,
      keyboard: { enabled: true, onlyInViewport: true },
      a11y: { enabled: true },
      on: {
        init(this: InstanceType<typeof Swiper>) {
          refreshControls(this);
        },
        slideChange(this: InstanceType<typeof Swiper>) {
          savedIndex[anchor] = this.activeIndex;
          refreshControls(this);
        },
      },
    });

    // Flechas: viven en el footer fijo (fuera del swiper), navegan por click delegado.
    viewportOf(swiper)?.addEventListener('click', (e: Event) => {
      const target = e.target as HTMLElement;
      if (target.closest('.photo-gallery__nav--next')) swiper.slideNext();
      else if (target.closest('.photo-gallery__nav--prev')) swiper.slidePrev();
    });

    swiper.disable();
    swipers[anchor] = swiper;
  }

  if (anchors.length) {
    swipers[anchors[0]].enable();
    updateSectionUI(anchors[0]);
  }

  new fullpage('#fullpage', {
    autoScrolling: true,
    fitToSection: true,
    navigation: false,
    anchors,
    scrollingSpeed: 700,
    keyboardScrolling: true,
    onLeave() {
      Object.values(swipers).forEach(s => s.disable());
      animateBrandLeave();
    },
    afterLoad(_origin: unknown, destination: { anchor: string }) {
      const swiper = swipers[destination.anchor];
      swiper.enable();
      swiper.slideTo(savedIndex[destination.anchor], 0);
      updateSectionUI(destination.anchor);
      animateBrandEnter();
    },
  });

  document.querySelectorAll<HTMLButtonElement>('.section-nav__item').forEach(item => {
    item.addEventListener('click', () => {
      if (item.dataset.anchor) (window as any).fullpage_api?.moveTo(item.dataset.anchor);
    });
  });

  // ── Menú de países ────────────────────────────────────────────
  const menuBtn = document.getElementById('js-menu-btn');
  const countryNav = document.getElementById('js-country-nav');
  const backdrop = document.getElementById('js-country-nav-backdrop');

  function openMenu(): void {
    countryNav?.classList.add('is-open');
    backdrop?.classList.add('is-open');
    countryNav?.setAttribute('aria-hidden', 'false');
    menuBtn?.setAttribute('aria-expanded', 'true');
  }

  function closeMenu(): void {
    countryNav?.classList.remove('is-open');
    backdrop?.classList.remove('is-open');
    countryNav?.setAttribute('aria-hidden', 'true');
    menuBtn?.setAttribute('aria-expanded', 'false');
  }

  menuBtn?.addEventListener('click', () => {
    countryNav?.classList.contains('is-open') ? closeMenu() : openMenu();
  });
  backdrop?.addEventListener('click', closeMenu);
  document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeMenu(); });
</script>

<style is:global>
  /* ─── Swiper theme overrides ─── */
  :root {
    --swiper-theme-color: #ffffff;
    --swiper-navigation-color: rgba(255, 255, 255, 0.85);
    --caption-height: 80px;
    --header-height: 60px;
    --nav-col-width: 160px;
    --viewport-top-extra: 56px;
    --viewport-bottom-clearance: 120px;
  }

  /* ─── Site header ─── */
  .site-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    height: var(--header-height);
    z-index: 50;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 24px 0 32px;
    background: linear-gradient(to bottom, rgba(0,0,0,0.6) 0%, transparent 100%);
    pointer-events: none;
  }

  .site-header__brand {
    display: flex;
    align-items: baseline;
    gap: 10px;
  }

  @keyframes brand-leave {
    from { opacity: 1; transform: translateY(0); }
    to   { opacity: 0; transform: translateY(-7px); }
  }

  @keyframes brand-enter {
    from { opacity: 0; transform: translateY(7px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .site-header__brand--leaving {
    animation: brand-leave 0.22s ease forwards;
  }

  .site-header__brand--entering {
    animation: brand-enter 0.28s ease forwards;
  }

  .site-header__title {
    font-family: 'Helvetica Neue', Arial, sans-serif;
    font-weight: 700;
    font-size: 0.95rem;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: #ffffff;
    text-shadow: 0 1px 8px rgba(0,0,0,0.5);
    transition: opacity 0.3s ease;
  }

  .site-header__sub {
    font-family: 'Georgia', serif;
    font-style: italic;
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    color: rgba(255,255,255,0.7);
    text-shadow: 0 1px 6px rgba(0,0,0,0.5);
  }

  .site-header__menu-btn {
    pointer-events: all;
    background: none;
    border: none;
    cursor: pointer;
    display: flex;
    flex-direction: column;
    gap: 5px;
    padding: 8px;

    span {
      display: block;
      width: 22px;
      height: 2px;
      background: rgba(255,255,255,0.85);
      border-radius: 1px;
      transition: background 0.2s;
    }

    &:hover span {
      background: #ffffff;
    }
  }

  /* ─── Section nav (bullets blancos) ─── */
  .section-nav {
    position: fixed; right: 0; width: var(--nav-col-width);
    top: 50%; transform: translateY(-50%);
    z-index: 50; display: flex; flex-direction: column; gap: 4px;
    align-items: flex-end; padding-right: 24px; box-sizing: border-box;
  }
  .section-nav__item {
    position: relative; background: none; border: none; cursor: pointer; padding: 4px 0;
    color: rgba(255,255,255,0.4);
    font-family: 'Helvetica Neue', Arial, sans-serif;
    font-size: 11.5px; font-weight: 600; letter-spacing: 0.18em; text-transform: uppercase;
    white-space: nowrap; text-align: right;
    text-shadow: 0 1px 4px rgba(0,0,0,0.6);
    transition: color 0.25s ease;
    &::before { content: attr(data-label); }
    &:hover { color: rgba(255,255,255,0.9); }
    &.section-nav__item--active { color: #ffffff; }
  }

  /* ─── fullpage.js watermark ─── */
  .fp-watermark {
    display: none;
  }

  /* ─── fullpage.js navigation dots ─── */
  #fp-nav ul li a span,
  #fp-nav ul li:hover a span {
    background: rgba(255, 255, 255, 0.7);
    box-shadow: 0 0 0 1.5px rgba(0, 0, 0, 0.35), 0 1px 6px rgba(0, 0, 0, 0.5);
  }
  #fp-nav ul li a.active span {
    background: #ffffff;
    width: 10px;
    height: 10px;
    margin: -5px 0 0 -5px;
    box-shadow: 0 0 0 1.5px rgba(0, 0, 0, 0.25), 0 2px 8px rgba(0, 0, 0, 0.6);
  }
  #fp-nav .fp-tooltip {
    color: #ffffff;
    font-family: 'Georgia', serif;
    font-size: 12px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    text-shadow: 0 1px 4px rgba(0, 0, 0, 0.7);
  }

  /* ─── Sections background ─── */
  .fp-section.photo-gallery__section {
    background: #000;
  }

  /* ─── photo-gallery block ─── */
  .photo-gallery {
    .photo-gallery__viewport {
      width: 1000px;
      margin-left: calc((100% - var(--nav-col-width) - 1000px) / 2);
      height: calc(100vh - var(--header-height) - var(--viewport-bottom-clearance));
      margin-top: calc(var(--header-height) + var(--viewport-top-extra));
      display: flex;
      flex-direction: column;
      gap: 16px;
    }

    .photo-gallery__carousel {
      position: relative;
      flex: 1;
      min-height: 0;
      width: 100%;
    }

    .photo-gallery__slide {
      height: 100%;
      overflow: hidden;

      &.photo-gallery__slide--intro {
        display: flex;
        align-items: center;
        justify-content: center;
        background: #000;
      }

      &:not(.photo-gallery__slide--intro) {
        display: flex;
        flex-direction: column;
      }
    }

    .photo-gallery__slide-media {
      flex: 1;
      min-height: 0;
      overflow: hidden;
      position: relative;
      background: #000;
    }

    .photo-gallery__image {
      display: block;
      width: 100%;
      height: auto;
      position: absolute;
      top: 50%;
      left: 0;
      transform: translateY(-50%);
      user-select: none;
      -webkit-user-drag: none;
      pointer-events: none;
    }

    /* ─── Footer: caption + controles en la misma barra ─── */
    .photo-gallery__footer {
      height: var(--caption-height);
      flex-shrink: 0;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 24px;
      padding: 0;
      background: #000;
    }

    .photo-gallery__caption {
      display: flex;
      flex-direction: column;
      justify-content: center;
      gap: 3px;
      min-width: 0;
      flex: 1;
    }

    .photo-gallery__caption-title {
      font-family: 'Helvetica Neue', Arial, sans-serif;
      font-size: 0.62rem;
      font-weight: 600;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: rgba(255, 255, 255, 0.4);
    }

    .photo-gallery__caption-desc {
      font-family: Arial, sans-serif;
      font-size: 15px;
      font-style: normal;
      letter-spacing: 0.06em;
      color: rgba(255, 255, 255, 0.75);
    }

    .photo-gallery__controls {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 35px;
      flex-shrink: 0;
    }

    .photo-gallery__nav-arrows {
      display: flex;
      align-items: center;
      gap: 15px;
    }

    .photo-gallery__viewport--intro-active {
      .photo-gallery__counter { color: rgba(122, 173, 223, 0.8); }
      .photo-gallery__nav { --swiper-navigation-color: rgba(122, 173, 223, 0.7); }
    }

    .photo-gallery__counter {
      color: rgba(255, 255, 255, 0.65);
      font-family: 'Georgia', serif;
      font-size: 0.9rem;
      letter-spacing: 0.12em;
      white-space: nowrap;
      font-variant-numeric: tabular-nums;
    }

    .photo-gallery__counter-current {
      display: inline-block;
      min-width: 2ch;
      text-align: right;
    }

    .photo-gallery__counter-sep {
      margin: 0 4px;
    }

    .photo-gallery__nav {
      width: 22px;
      height: 22px;
      display: flex;
      align-items: center;
      justify-content: center;
      background: none;
      border: none;
      padding: 0;
      cursor: pointer;
      opacity: 0.85;
      transition: opacity 0.2s ease;

      &::after {
        content: '';
        width: 15px;
        height: 15px;
        border-right: 2.8px solid var(--swiper-navigation-color);
        border-bottom: 2.8px solid var(--swiper-navigation-color);
        filter: drop-shadow(0 1px 3px rgba(0, 0, 0, 0.8));
      }

      &.photo-gallery__nav--prev::after {
        transform: rotate(135deg);
        margin-left: 3px;
      }

      &.photo-gallery__nav--next::after {
        transform: rotate(-45deg);
        margin-right: 3px;
      }

      &:hover {
        opacity: 1;
      }
    }

    /* ─── Intro slide content ─── */
    .photo-gallery__intro {
      text-align: center;
      padding: 2rem;
      max-width: 700px;
    }

    .photo-gallery__intro-heading {
      font-family: 'Helvetica Neue', Arial, sans-serif;
      font-size: clamp(1.8rem, 5vw, 3.5rem);
      font-weight: 400;
      color: #7aaddf;
      letter-spacing: 0.04em;
      margin: 0;
      line-height: 1;
    }

    .photo-gallery__intro-tagline {
      font-family: 'Georgia', 'Times New Roman', serif;
      font-style: italic;
      font-size: clamp(1rem, 2vw, 1.35rem);
      color: #7aaddf;
      margin: 0.5em 0 0;
    }

    .photo-gallery__intro-body {
      font-family: Arial, 'Helvetica Neue', sans-serif;
      font-size: clamp(0.82rem, 1.4vw, 1rem);
      color: rgba(255, 255, 255, 0.75);
      max-width: 580px;
      margin: 1.6em auto 0;
      line-height: 1.7;
      text-align: justify;
    }
  }

  /* ─── Menú de países ─── */
  .country-nav {
    position: fixed;
    top: 0;
    right: 0;
    width: 200px;
    height: 100%;
    background: rgba(0, 0, 0, 0.88);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    transform: translateX(100%);
    transition: transform 0.3s ease;
    z-index: 200;
    padding: 4rem 2rem;
    box-sizing: border-box;

    &.is-open {
      transform: translateX(0);
    }
  }

  .country-nav__backdrop {
    position: fixed;
    inset: 0;
    z-index: 199;
    display: none;

    &.is-open {
      display: block;
    }
  }

  .country-nav__list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .country-nav__link {
    display: block;
    padding: 0.75rem 0;
    color: rgba(255, 255, 255, 0.45);
    text-decoration: none;
    font-family: 'Helvetica Neue', Arial, sans-serif;
    font-size: 11.5px;
    font-weight: 600;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    transition: color 0.2s ease;

    &[data-current] {
      color: #ffffff;
    }

    &:hover {
      color: rgba(255, 255, 255, 0.85);
    }
  }
  .country-nav__separator {
    padding: 0.75rem 0 0.25rem; margin-top: 0.5rem;
    color: rgba(255,255,255,0.25); font-family: 'Helvetica Neue', Arial, sans-serif;
    font-size: 0.5rem; font-weight: 600; letter-spacing: 0.3em; text-transform: uppercase;
    border-top: 1px solid rgba(255,255,255,0.1); list-style: none;
  }

  /* ─── Pantallas cortas (laptops con poco alto) ─── */
  @media (max-height: 700px) {
    :root {
      --caption-height: 64px;
      --viewport-top-extra: 32px;
      --viewport-bottom-clearance: 88px;
    }
  }

  @media (max-height: 580px) {
    :root {
      --caption-height: 52px;
      --viewport-top-extra: 16px;
      --viewport-bottom-clearance: 64px;
    }
  }

  /* ─── Mobile ─── */
  @media (max-width: 768px) {
    .site-header {
      padding: 0 16px 0 20px;
    }

    /* Bullets verticales pegados al margen derecho */
    .section-nav { right: 12px; left: auto; top: 50%; bottom: auto; transform: translateY(-50%); flex-direction: column; width: auto; gap: 8px; align-items: center; padding-right: 0; }
    .section-nav__item {
      width: 6px; height: 6px; border-radius: 50%; background: rgba(255,255,255,0.3); padding: 0; font-size: 0;
      &::before { content: none; }
      &:hover { background: rgba(255,255,255,0.65); transform: scale(1.25); }
      &.section-nav__item--active { background: #ffffff; transform: scale(1.2); box-shadow: 0 0 6px rgba(255,255,255,0.5); }
    }

    .photo-gallery {
      /* Foto ocupa todo el ancho, márgenes reducidos */
      .photo-gallery__viewport {
        width: 100%;
        margin-left: 0;
        height: calc(100dvh - var(--header-height) - 40px);
        margin-top: calc(var(--header-height) + 8px);
        gap: 12px;
      }

      .photo-gallery__nav {
        display: none;
      }

      .photo-gallery__intro-body {
        text-align: left;
      }

      .photo-gallery__footer {
        padding: 0 20px;
      }
    }
  }
</style>
